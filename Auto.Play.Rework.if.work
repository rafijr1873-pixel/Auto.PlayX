-- §3  KEY SYSTEM (reversed strings)
-- ════════════════════════════════════════════
local R=string.reverse
local _KEYS={
    R("4202-PIV-MURDOTUA"),
    R("666-NOSIDROJ-YEOJ"),
    R("X-MUIMERP-TOGGAM"),
    R("ORP-SMURD-IFAR"),
    R("99-REVEROF-LATEM"),
}
local function checkKey(input)
    local k=input:upper():gsub("%s+","")
    for _,v in ipairs(_KEYS) do if k==v then return true end end
    return false
end
local isPremium=_G._DrumPremium or false
local FREE_SONGS={1,8,9}
local function isSongFree(i)
    for _,v in ipairs(FREE_SONGS) do if v==i then return true end end
    return false
end

