-- ════════════════════════════════════════════
-- §7  CORE ENGINE (with speed)
-- ════════════════════════════════════════════
local function hum(fast)
    local ms=fast and RNG:NextInteger(5,16) or RNG:NextInteger(16,45)
    return(ms/1000)*((RNG:NextInteger(0,1)==0)and 1 or-1)
end

local function press(keys,fast)
    if typeof(keys)=="EnumItem" then keys={keys} end
    for i=1,#keys do VIM:SendKeyEvent(true,keys[i],false,game) end
    task.wait(fast and RNG:NextInteger(22,42)/1000 or RNG:NextInteger(48,100)/1000)
    for i=1,#keys do VIM:SendKeyEvent(false,keys[i],false,game) end
    totalHits=totalHits+1
    local now=tick(); recentHits[#recentHits+1]=now
    while #recentHits>0 and now-recentHits[1]>3 do table.remove(recentHits,1) end
end

local function getNPS()
    local now=tick()
    while #recentHits>0 and now-recentHits[1]>3 do table.remove(recentHits,1) end
    return math.floor(#recentHits/3*10)/10
end

local function ok() return _G._AD end

local function bar(pat,sub,bpm)
    barN=barN+1; local base=(60/bpm/(sub==16 and 4 or 2))/speedMul; local f=sub==16
    for i=1,#pat do
        if not ok() then return false end
        if pat[i] then press(pat[i],f) end
        local d=base+hum(f)/speedMul; if d<0.02 then d=0.02 end; task.wait(d)
    end; return ok()
end

local function sec(name,bars,sub,bpm)
    secN=name; for i=1,#bars do
        if not bar(bars[i],sub,bpm) then return false end
    end; return ok()
end

-- ════════════════════════════════════════════
-- §8  MIDI PARSER
-- ════════════════════════════════════════════
local MP={}
function MP.parse(raw)
    if not raw or #raw<14 then return nil,"File too small" end
    local pos,len=1,#raw
    local function rb() if pos>len then error("EOF") end; local b=string.byte(raw,pos); pos=pos+1; return b end
    local function rn(n) local v=0; for _=1,n do v=v*256+rb() end; return v end
    local function rs(n) if pos+n-1>len then error("EOF") end; local s=raw:sub(pos,pos+n-1); pos=pos+n; return s end
    local function rvlq() local v,c=0,0; repeat local b=rb(); v=v*128+(b%128); c=c+1; if c>4 then error("VLQ") end until b<128; return v end
    local hdr=rs(4); if hdr~="MThd" then return nil,"Not MIDI" end
    local hl=rn(4);rn(2);local nT=rn(2);local div=rn(2)
    if hl>6 then pos=pos+(hl-6) end
    if div>=32768 then return nil,"SMPTE unsupported" end
    local ppq,notes,tempos=div,{},{}
    for t=1,nT do
        if pos+8>len then break end
        local th=rs(4); if th~="MTrk" then return nil,"No MTrk" end
        local tl=rn(4);local te=pos+tl;local at,run=0,0
        while pos<te and pos<=len do
            local d=rvlq();at=at+d;if pos>len then break end
            local pk=string.byte(raw,pos);if not pk then break end
            local st;if pk>=128 then st=rb();if st<0xF0 then run=st end
            else st=run;if st==0 then rb();break end end
            local hi=math.floor(st/16)
            if hi==9 then local n,v=rb(),rb()
                if v>0 and #notes<30000 then notes[#notes+1]={at,n,v,st%16} end
            elseif hi==8 or hi==10 or hi==11 or hi==14 then rb();rb()
            elseif hi==12 or hi==13 then rb()
            elseif st==0xFF then local mt=rb();local ml=rvlq()
                if mt==0x51 and ml>=3 then local us=0;for _=1,3 do us=us*256+rb() end
                    tempos[#tempos+1]={at,us};if ml>3 then pos=pos+(ml-3) end
                else pos=pos+ml end
            elseif st==0xF0 or st==0xF7 then pos=pos+rvlq()
            else pos=te end
        end;pos=te
    end
    if #notes==0 then return nil,"No notes" end
    table.sort(notes,function(a,b)return a[1]<b[1]end)
    table.sort(tempos,function(a,b)return a[1]<b[1]end)
    return notes,tempos,ppq
end

function MP.build(notes,tempos,ppq)
    local has9=false;for _,n in ipairs(notes) do if n[4]==9 then has9=true;break end end
    local dn={};for _,n in ipairs(notes) do
        if(has9 and n[4]==9)or not has9 then local key=GM[n[2]];if key then dn[#dn+1]={tick=n[1],key=key}end end
    end
    if #dn==0 then return nil,0,0,0,"No drum notes" end
    if #tempos==0 or tempos[1][1]~=0 then table.insert(tempos,1,{0,500000})end
    local tl={};local cs,pt,ptm=0,0,500000
    for _,tc in ipairs(tempos) do cs=cs+(tc[1]-pt)*ptm/ppq/1e6;tl[#tl+1]={tick=tc[1],sec=cs,tempo=tc[2]};pt=tc[1];ptm=tc[2] end
    local function t2s(tick) local s,p,tm=0,0,500000;for _,t in ipairs(tl) do if t.tick>tick then break end;s=t.sec;p=t.tick;tm=t.tempo end;return s+(tick-p)*tm/ppq/1e6 end
    local gr,tks={},{};for _,d in ipairs(dn) do local t=d.tick;if not gr[t] then gr[t]={};tks[#tks+1]=t end
        local dup=false;for _,k in ipairs(gr[t]) do if k==d.key then dup=true end end;if not dup then gr[t][#gr[t]+1]=d.key end end
    table.sort(tks);local seq={};for _,t in ipairs(tks) do seq[#seq+1]={time=t2s(t),keys=gr[t]}end
    return seq,seq[#seq]and seq[#seq].time or 0,math.floor(60e6/(tempos[1][2]or 5e5)+0.5),#dn,nil
end

-- ════════════════════════════════════════════
-- §9  MIDI LOAD & PLAY (with progress + auto-next)
-- ════════════════════════════════════════════
local function fetch(url)
    local body,s,e;s,e=pcall(function()
        if syn and syn.request then body=syn.request({Url=url,Method="GET"}).Body
        elseif http_request then body=http_request({Url=url,Method="GET"}).Body
        elseif request then body=request({Url=url,Method="GET"}).Body
        elseif httpget then body=httpget(url)
        else body=game:HttpGet(url)end
    end);return s and body or nil,tostring(e or"")
end

local function loadMidi(url,cb)
    if not url or url==""then return nil,"No URL"end
    cb("⏳ Fetching...");local raw,fe=fetch(url)
    if not raw then return nil,"Fetch: "..(fe or"?")end
    if #raw<14 then return nil,"Too small"end
    cb("⏳ Parsing...");local notes,tempos,ppq=MP.parse(raw)
    if not notes then return nil,tempos end
    cb("⏳ Building...");local seq,dur,bpm,cnt,err=MP.build(notes,tempos,ppq)
    if not seq then return nil,err end
    return{seq=seq,duration=dur,bpm=bpm,noteCount=cnt}
end

-- Forward declare for auto-next
local doLoadMidi

local function getAvailableSongs()
    local avail={}
    for i,p in ipairs(PRESETS) do
        if isPremium or isSongFree(i) then avail[#avail+1]=i end
    end
    return avail
end

local function pickNextSong()
    local avail=getAvailableSongs()
    if #avail==0 then return nil end
    if shuffleOn then
        return avail[RNG:NextInteger(1,#avail)]
    else
        if not activeSongIdx then return avail[1] end
        for i,idx in ipairs(avail) do
            if idx==activeSongIdx then
                return avail[(i%#avail)+1]
            end
        end
        return avail[1]
    end
end

local function fmtTime(s)
    s=math.max(0,math.floor(s))
    return string.format("%d:%02d",math.floor(s/60),s%60)
end

local function midiLoop()
    if not midiObj or #midiObj.seq==0 then secN="NO MIDI";task.wait(1);return end
    secN="♫ "..currentSong
    local seq=midiObj.seq
    local dur=midiObj.duration/speedMul
    local st=tick()
    for i=1,#seq do
        if not ok() then midiProgress=0;return end
        local tgt=st+seq[i].time/speedMul
        local now=tick()
        if tgt>now+0.003 then task.wait(tgt-now) end
        if not ok() then midiProgress=0;return end
        press(seq[i].keys,true)
        barN=math.floor(i/16)
        midiProgress=i/#seq
        local elapsed=(tick()-st)
        midiTimeStr=fmtTime(elapsed).."/"..fmtTime(dur)
    end
    loopCount=loopCount+1
    midiProgress=1;midiTimeStr=fmtTime(dur).."/"..fmtTime(dur)

    -- Auto-next logic
    if autoNextOn and ok() then
        secN="⏭ NEXT..."
        task.wait(0.8)
        if ok() then
            local nxt=pickNextSong()
            if nxt then
                _G._AD=false
                task.wait(0.15)
                activeSongIdx=nxt
                doLoadMidi(PRESETS[nxt].url,PRESETS[nxt].name)
                return
            end
        end
    else
        secN="↻ LOOP";task.wait(0.5)
    end
end

