local fA={{K.Sn,K.CR},{K.Sn2},{K.T1,K.Ki},{K.T1B,K.Ki2},{K.T2,K.Ki},{K.T2B,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.Ki,K.Ki2},{K.Sn},{K.T1,K.Ki},{K.T2,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.SnS,K.Ki,K.Ki2},{K.CL,K.CR,K.Ch,K.Ki,K.Ki2}}
local tA={{K.CL,K.CR,K.Ch,K.Sp,K.Ki,K.Ki2},nil,nil,nil,nil,nil,nil,nil}
local function eyelessLoop()
    if introD then introD=false
        if not sec("⚡ INTRO",{iA,iB,iC,iD},8,E)then return end end
    if not sec("♫ VERSE",{vA,vA,vB,vC,vA,vB,vD,vC},8,E)then return end
    if not sec("⬆ PRE-CH",{pA,pB,pF},8,E)then return end
    if not sec("★ CHORUS",{cA,cA,cB,cA,cFl},16,E)then return end
    if not sec("♫ VRS.2",{vB,vD,vC,vB},8,E)then return end
    if not sec("⬆ PRE-C2",{pB,pA,pF},8,E)then return end
    if not sec("★ CHOR.2",{cA,cC,cB,cC,cFl},16,E)then return end
    if not sec("⬛ BREAK",{bA,bA,bB,bC,bF},8,E)then return end
    if not sec("‼ BLAST",{xA,xB},16,E)then return end
    if not sec("↓ FILL",{fA},16,E)then return end
    sec("→ LOOP",{tA},8,E)
end

-- ════════════════════════════════════════════
-- §11  PATTERN REGISTRY + START/STOP
-- ════════════════════════════════════════════
local PATS={
    {name="Rock",bpm=120,fn=rockLoop},
    {name="Eyeless♫",bpm=142,fn=eyelessLoop,premium=true},
    {name="MIDI",bpm=0,fn=midiLoop},
}
local function go()
    if _G._AD then return end;_G._AD=true;barN=0;midiProgress=0
    task.spawn(function()while _G._AD do
        local s,e=pcall(PATS[pIdx].fn)
        if not s then warn("[Drum] "..tostring(e));task.wait(0.3)end
    end end)
end
local function stop()
    _G._AD=false;secN="IDLE";midiProgress=0
    pcall(function()for _,v in pairs(K)do VIM:SendKeyEvent(false,v,false,game)end end)
end

-- ════════════════════════════════════════════
-- §12  ANTI-AFK
-- ════════════════════════════════════════════
task.spawn(function()
    while true do
        if antiAfk then
            pcall(function()
                local c=plr.Character
                if c then
                    local h=c:FindFirstChildOfClass("Humanoid")
                    if h then
                        -- Micro-jump that's barely visible
                        VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game)
                        task.wait(0.05)
                        VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game)
                    end
                end
            end)
        end
        task.wait(180)
    end
end)

-- Also hook Idled event
pcall(function()
    plr.Idled:Connect(function()
        if antiAfk then
            VIM:SendKeyEvent(true,Enum.KeyCode.Return,false,game)
            task.wait(0.1)
            VIM:SendKeyEvent(false,Enum.KeyCode.Return,false,game)
        end
    end)
end)

-- ════════════════════════════════════════════
-- §13  AUTO-SIT
-- ════════════════════════════════════════════
local function autoSit()
    local c=plr.Character
    if not c then return false,"No character" end
    local root=c:FindFirstChild("HumanoidRootPart")
    local hum=c:FindFirstChildOfClass("Humanoid")
    if not root or not hum then return false,"No humanoid" end
    if hum.Sit then return false,"Already sitting" end
    local best,dist=nil,math.huge
    for _,obj in ipairs(workspace:GetDescendants()) do
        pcall(function()
            if(obj:IsA("Seat")or obj:IsA("VehicleSeat"))and not obj.Occupant then
                local d=(obj.Position-root.Position).Magnitude
                if d<dist then best=obj;dist=d end
            end
        end)
    end
    if best and dist<100 then
        root.CFrame=best.CFrame+Vector3.new(0,3,0)
        task.wait(0.5)
        if best and best.Parent then
            pcall(function()best:Sit(hum)end)
        end
        return true,"Sat at drum! ("..math.floor(dist).."m)"
    end
    return false,"No seat found nearby"
end

-- ════════════════════════════════════════════
-- §14  GUI HELPERS
-- ════════════════════════════════════════════
local function mkBtn(p,sz,ps,bg,txt,tc,ts)
    local b=Instance.new("TextButton",p)
    b.Size=sz;b.Position=ps;b.BackgroundColor3=bg
    b.Text=txt;b.TextColor3=tc or Color3.new(1,1,1)
    b.TextSize=ts or 10;b.Font=Enum.Font.GothamBold
    b.AutoButtonColor=true
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,7)
    return b
end
local function mkLbl(p,sz,ps,txt,tc,ts,fnt)
    local l=Instance.new("TextLabel",p)
    l.Size=sz;l.Position=ps;l.BackgroundTransparency=1
    l.Text=txt;l.TextColor3=tc or Color3.fromRGB(130,130,130)
    l.TextSize=ts or 10;l.Font=fnt or Enum.Font.Gotham
    return l
end

