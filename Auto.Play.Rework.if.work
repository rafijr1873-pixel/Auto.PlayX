    local grid=Instance.new("UIGridLayout",scroll)
    grid.CellSize=UDim2.new(0,122,0,34);grid.CellPadding=UDim2.new(0,3,0,3)
    grid.FillDirection=Enum.FillDirection.Horizontal
    grid.HorizontalAlignment=Enum.HorizontalAlignment.Center
    grid.SortOrder=Enum.SortOrder.LayoutOrder
    local gPad=Instance.new("UIPadding",scroll)
    gPad.PaddingTop=UDim.new(0,3);gPad.PaddingBottom=UDim.new(0,3)

    local qBtns={}
    for i,preset in ipairs(PRESETS) do
        local free=isSongFree(i);local locked=not isPremium and not free
        local btn=mkBtn(scroll,UDim2.new(0,122,0,34),UDim2.new(0,0,0,0),
            locked and Color3.fromRGB(32,32,42) or preset.color,
            locked and "🔒 "..preset.name or preset.name,
            locked and Color3.fromRGB(90,90,100) or Color3.new(1,1,1),9)
        btn.Name="S"..i;btn.LayoutOrder=i
        btn.TextYAlignment=Enum.TextYAlignment.Top
        btn.TextTruncate=Enum.TextTruncate.AtEnd
        btn.BackgroundTransparency=locked and 0.3 or 0.1
        Instance.new("UIPadding",btn).PaddingTop=UDim.new(0,3)
        local sub=mkLbl(btn,UDim2.new(1,-4,0,10),UDim2.new(0,2,1,-12),
            locked and "Premium" or preset.artist,
            locked and Color3.fromRGB(70,70,80) or Color3.fromRGB(200,200,200),7)
        sub.TextTransparency=0.35
        qBtns[i]=btn
    end

    -- ── Progress Bar (y=248, h=14) ──
    local progBg=Instance.new("Frame",mf)
    progBg.Size=UDim2.new(1,-12,0,10);progBg.Position=UDim2.new(0,6,0,248)
    progBg.BackgroundColor3=Color3.fromRGB(28,28,48);progBg.BorderSizePixel=0
    Instance.new("UICorner",progBg).CornerRadius=UDim.new(0,5)

    local progFill=Instance.new("Frame",progBg)
    progFill.Size=UDim2.new(0,0,1,0)
    progFill.BackgroundColor3=Color3.fromRGB(255,170,40)
    progFill.BorderSizePixel=0
    Instance.new("UICorner",progFill).CornerRadius=UDim.new(0,5)

    local progLbl=mkLbl(mf,UDim2.new(1,-12,0,12),UDim2.new(0,6,0,260),
        "0:00/0:00 · 0%",Color3.fromRGB(90,90,110),8)

    -- ── Custom MIDI (y=276) ──
    mkLbl(mf,UDim2.new(1,-12,0,13),UDim2.new(0,6,0,276),
        "── 🔗 CUSTOM MIDI ──",Color3.fromRGB(90,150,240),9,Enum.Font.GothamBold)

    local urlBox=Instance.new("TextBox",mf)
    urlBox.Size=UDim2.new(1,-12,0,24);urlBox.Position=UDim2.new(0,6,0,292)
    urlBox.BackgroundColor3=Color3.fromRGB(18,18,38);urlBox.BackgroundTransparency=0.05
    urlBox.BorderSizePixel=0;urlBox.Text="";urlBox.PlaceholderText="  Paste .mid URL..."
    urlBox.PlaceholderColor3=Color3.fromRGB(60,60,90)
    urlBox.TextColor3=Color3.fromRGB(200,210,255);urlBox.TextSize=9
    urlBox.Font=Enum.Font.Gotham;urlBox.ClearTextOnFocus=false
    urlBox.TextXAlignment=Enum.TextXAlignment.Left
    urlBox.TextTruncate=Enum.TextTruncate.AtEnd
    Instance.new("UICorner",urlBox).CornerRadius=UDim.new(0,6)
    Instance.new("UIStroke",urlBox).Color=Color3.fromRGB(50,50,85)
    Instance.new("UIPadding",urlBox).PaddingLeft=UDim.new(0,6)

    local loadBtn=mkBtn(mf,UDim2.new(0,78,0,20),UDim2.new(0,6,0,320),
        Color3.fromRGB(45,45,105),"📥 LOAD",Color3.new(1,1,1),9)
    local midiLbl=mkLbl(mf,UDim2.new(0,170,0,20),UDim2.new(0,90,0,320),
        "No MIDI loaded",Color3.fromRGB(85,85,100),8)
    midiLbl.TextXAlignment=Enum.TextXAlignment.Left
    midiLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- ── Status Lines (y=346..420) ──
    local s1=mkLbl(mf,UDim2.new(1,-12,0,15),UDim2.new(0,6,0,346),
        "⏹ Rock · 120 BPM · 1.0x",Color3.fromRGB(130,130,130),11,Enum.Font.GothamBold)
    local s2=mkLbl(mf,UDim2.new(1,-12,0,13),UDim2.new(0,6,0,363),
        "Bar: 0 │ Loop: 0 │ Tap ▶ or P",Color3.fromRGB(85,85,100),9)
    local npLbl=mkLbl(mf,UDim2.new(1,-12,0,12),UDim2.new(0,6,0,378),
        "",Color3.fromRGB(255,200,60),9,Enum.Font.GothamBold)
    npLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- Footer
    local footerLbl=mkLbl(mf,UDim2.new(1,-12,0,11),UDim2.new(0,6,0,394),
        isPremium and "⭐ PREMIUM │ v7.0 Reworked" or "🆓 FREE │ 🔑 upgrade │ v7.0",
        isPremium and Color3.fromRGB(200,170,40) or Color3.fromRGB(85,85,105),8)

    -- Credit
    mkLbl(mf,UDim2.new(1,-12,0,10),UDim2.new(0,6,0,408),
        "by rafijr1873 · github.com/rafijr1873-pixel",
        Color3.fromRGB(50,50,70),7)

    -- ════════════════════════════════════════
    -- SECTION COLORS
    -- ════════════════════════════════════════
    local SC={
        ["Rock"]=Color3.fromRGB(100,220,130),["⚡ INTRO"]=Color3.fromRGB(160,160,160),
        ["♫ VERSE"]=Color3.fromRGB(100,200,255),["♫ VRS.2"]=Color3.fromRGB(80,180,230),
        ["⬆ PRE-CH"]=Color3.fromRGB(255,200,80),["⬆ PRE-C2"]=Color3.fromRGB(255,220,60),
        ["★ CHORUS"]=Color3.fromRGB(255,120,40),["★ CHOR.2"]=Color3.fromRGB(255,80,20),
        ["⬛ BREAK"]=Color3.fromRGB(180,80,255),["‼ BLAST"]=Color3.fromRGB(255,40,40),
        ["↓ FILL"]=Color3.fromRGB(255,220,60),["→ LOOP"]=Color3.fromRGB(120,255,120),
        ["NO MIDI"]=Color3.fromRGB(255,80,80),["↻ LOOP"]=Color3.fromRGB(120,255,180),
        ["⏭ NEXT..."]=Color3.fromRGB(100,200,255),["IDLE"]=Color3.fromRGB(130,130,130),
    }

    -- ════════════════════════════════════════
    -- HIGHLIGHT MANAGEMENT
    -- ════════════════════════════════════════
    local function clearHL()
        for i,btn in ipairs(qBtns) do
            local locked=not isPremium and not isSongFree(i)
            btn.BackgroundTransparency=locked and 0.3 or 0.1
            for _,c in ipairs(btn:GetChildren()) do if c:IsA("UIStroke")then c:Destroy()end end
        end
    end
    local function hlSong(name)
        clearHL()
        for i,btn in ipairs(qBtns) do
            if PRESETS[i].name==name then
                btn.BackgroundTransparency=0
                local st=Instance.new("UIStroke",btn)
                st.Color=Color3.fromRGB(255,255,100);st.Thickness=2
            end
        end
    end

    -- ════════════════════════════════════════
    -- FILTER LOGIC
    -- ════════════════════════════════════════
    local function applyFilter(tag)
        curFilter=tag
        for i,fb in ipairs(filterBtns) do
            fb.BackgroundColor3=FILTERS[i]==tag and Color3.fromRGB(70,70,120) or Color3.fromRGB(30,30,50)
        end
        for i,btn in ipairs(qBtns) do
            if tag=="All" then btn.Visible=true
            else btn.Visible=(PRESETS[i].tag==tag:sub(1,2)..(tag:sub(3) or "")
                or PRESETS[i].tag==tag
                or PRESETS[i].artist:find(tag))
            end
        end
    end
    -- Fix filter matching
    local tagMap={All="All",Slipknot="SK",Megadeth="MG",A7X="A7X"}
    local function applyFilter2(name)
        curFilter=name;local t=tagMap[name]
        for i,fb in ipairs(filterBtns) do
            fb.BackgroundColor3=FILTERS[i]==name and Color3.fromRGB(70,70,120) or Color3.fromRGB(30,30,50)
        end
        for i,btn in ipairs(qBtns) do
            btn.Visible=(t=="All" or PRESETS[i].tag==t)
        end
    end

    -- ════════════════════════════════════════
    -- REFRESH
    -- ════════════════════════════════════════
    local function refresh()
        local p=PATS[pIdx]
        patBtn.Text=p.name.." ▸"
        spdBtn.Text=speedMul.."x ▸"

        -- Toggle btn
        if _G._AD then
            togBtn.Text="⏸ STOP";togBtn.BackgroundColor3=Color3.fromRGB(170,25,25)
        else
            togBtn.Text="▶ PLAY";togBtn.BackgroundColor3=Color3.fromRGB(0,150,48)
        end

        -- Feature toggles
        afkBtn.BackgroundColor3=antiAfk and Color3.fromRGB(30,80,30) or Color3.fromRGB(40,40,55)
        afkBtn.Text=antiAfk and "🛡 ON" or "🛡 Off"
        afkBtn.TextColor3=antiAfk and Color3.fromRGB(150,255,150) or Color3.fromRGB(120,120,140)

        shufBtn.BackgroundColor3=shuffleOn and Color3.fromRGB(80,50,110) or Color3.fromRGB(40,40,55)
        shufBtn.Text=shuffleOn and "🔀 On" or "🔀 Off"
        shufBtn.TextColor3=shuffleOn and Color3.fromRGB(200,160,255) or Color3.fromRGB(120,120,140)

        nextBtn.BackgroundColor3=autoNextOn and Color3.fromRGB(30,60,110) or Color3.fromRGB(40,40,55)
        nextBtn.Text=autoNextOn and "⏭ On" or "⏭ Off"
        nextBtn.TextColor3=autoNextOn and Color3.fromRGB(150,200,255) or Color3.fromRGB(120,120,140)

        -- Hits
        hitsLbl.Text="🎵 "..totalHits.." · "..getNPS().."/s"

        -- BPM
        local bStr=(p.name=="MIDI" and midiObj) and tostring(midiObj.bpm)
            or (p.name=="MIDI" and "---" or tostring(p.bpm))

        -- Status
        if _G._AD then
            s1.Text=secN.." · "..bStr.." BPM · "..speedMul.."x"
            s1.TextColor3=SC[secN] or Color3.fromRGB(80,255,90)
            s2.Text="Bar:"..barN.." │ Loop:"..loopCount.." │ 🟢"
            s2.TextColor3=Color3.fromRGB(55,175,55)
        else
            s1.Text="⏹ "..p.name.." · "..bStr.." BPM · "..speedMul.."x"
            s1.TextColor3=Color3.fromRGB(130,130,130)
            s2.Text="Bar:"..barN.." │ Loop:"..loopCount.." │ Tap ▶ or P"
            s2.TextColor3=Color3.fromRGB(85,85,100)
        end

        -- MIDI label
        if midiObj and not midiLoading then
            midiLbl.Text="✅ "..midiObj.noteCount.."n · "
                ..string.format("%.0fs",midiObj.duration).." · "..midiObj.bpm.."BPM"
            midiLbl.TextColor3=Color3.fromRGB(80,255,80)
        elseif not midiLoading then
            midiLbl.Text="No MIDI loaded"
            midiLbl.TextColor3=Color3.fromRGB(85,85,100)
        end

        -- Now playing
        npLbl.Text=currentSong~="" and ("♪ "..currentSong) or ""

        -- Progress bar
        local pct=math.clamp(midiProgress,0,1)
        progFill.Size=UDim2.new(pct,0,1,0)
        progFill.BackgroundColor3=pct>=1 and Color3.fromRGB(80,255,80)
            or Color3.fromRGB(255,170,40)
        if pIdx==3 and midiObj then
            progLbl.Text=midiTimeStr.." · "..math.floor(pct*100).."%"
            progLbl.TextColor3=_G._AD and Color3.fromRGB(200,180,80) or Color3.fromRGB(90,90,110)
        else
            progLbl.Text="Pattern mode · ∞ loop"
            progLbl.TextColor3=Color3.fromRGB(90,90,110)
        end
    end

    -- Live updater
    task.spawn(function()
        while gui and gui.Parent do pcall(refresh);task.wait(0.22) end
    end)

    -- ════════════════════════════════════════
    -- ACTIONS
    -- ════════════════════════════════════════
    local function toggle()
        if _G._AD then stop() else go() end;refresh()
    end

    local function cyclePattern()
        local was=_G._AD;if was then stop();task.wait(0.15) end
        local n=pIdx+1;if n>2 then n=1 end
        if PATS[n].premium and not isPremium then n=1 end
        pIdx=n;barN=0;introD=true;secN="IDLE";currentSong=""
        loopCount=0;midiProgress=0;clearHL();refresh()
        if was then go();refresh() end
    end

    local function cycleSpeed()
        speedIdx=speedIdx%#SPEEDS+1
        speedMul=SPEEDS[speedIdx]
        refresh()
    end

    -- MIDI Loader
    doLoadMidi=function(url,songName)
        if midiLoading then return end;midiLoading=true
        local was=_G._AD;if was then stop();task.wait(0.15) end
        loadBtn.Text="⏳...";loadBtn.BackgroundColor3=Color3.fromRGB(80,80,40)
        hlSong(songName)
        task.spawn(function()
            local data,err=loadMidi(url,function(msg)
                midiLbl.Text=msg;midiLbl.TextColor3=Color3.fromRGB(255,200,60)
            end)
            midiLoading=false;loadBtn.Text="📥 LOAD"
            loadBtn.BackgroundColor3=Color3.fromRGB(45,45,105)
            if data then
                midiObj=data;currentSong=songName or "Custom"
                pIdx=3;barN=0;secN="IDLE";loopCount=0;midiProgress=0
                -- Find which preset index
                for i,p in ipairs(PRESETS) do
                    if p.name==songName then activeSongIdx=i;break end
                end
                hlSong(songName);refresh()
                task.wait(0.2)
                if not _G._AD then go();refresh() end
                pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title="🥁 "..currentSong,Text=data.noteCount.." notes · "..data.bpm.." BPM",Duration=3})end)
            else
                midiLbl.Text="❌ "..tostring(err):sub(1,26)
                midiLbl.TextColor3=Color3.fromRGB(255,70,70);clearHL()
            end
        end)
    end

    -- In-app key upgrade
    local function showKeyPopup()
        if isPremium then
            pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{
                Title="⭐ Already Premium!",Text="All features active.",Duration=2})end)
            return
        end
        local kd=Instance.new("Frame",gui)
        kd.Size=UDim2.new(0,240,0,125);kd.Position=UDim2.new(0.5,-120,0.35,0)
        kd.BackgroundColor3=Color3.fromRGB(14,14,28);kd.BorderSizePixel=0
        kd.Active=true;kd.Draggable=true;kd.ZIndex=20
        Instance.new("UICorner",kd).CornerRadius=UDim.new(0,10)
        Instance.new("UIStroke",kd).Color=Color3.fromRGB(255,170,0)
        mkLbl(kd,UDim2.new(1,0,0,20),UDim2.new(0,0,0,6),
            "🔑 Enter Premium Key",Color3.fromRGB(255,200,50),12,Enum.Font.GothamBold)
        local kb=Instance.new("TextBox",kd)
        kb.Size=UDim2.new(0.85,0,0,26);kb.Position=UDim2.new(0.075,0,0,30)
        kb.BackgroundColor3=Color3.fromRGB(22,22,44);kb.BorderSizePixel=0
        kb.Text="";kb.PlaceholderText="  KEY-HERE"
        kb.PlaceholderColor3=Color3.fromRGB(65,65,90)
        kb.TextColor3=Color3.fromRGB(255,220,100);kb.TextSize=12;kb.Font=Enum.Font.GothamBold
        Instance.new("UICorner",kb).CornerRadius=UDim.new(0,7)
        Instance.new("UIPadding",kb).PaddingLeft=UDim.new(0,6)
        local ku=mkBtn(kd,UDim2.new(0.4,0,0,24),UDim2.new(0.06,0,0,64),
            Color3.fromRGB(190,150,20),"UNLOCK",Color3.fromRGB(15,15,5),10)
        local kc=mkBtn(kd,UDim2.new(0.4,0,0,24),UDim2.new(0.54,0,0,64),
            Color3.fromRGB(70,25,25),"Cancel",Color3.new(1,1,1),10)
        local ks=mkLbl(kd,UDim2.new(1,0,0,14),UDim2.new(0,0,0,94),
            "",Color3.fromRGB(110,110,130),9)
        ku.MouseButton1Click:Connect(function()
            if checkKey(kb.Text) then
                isPremium=true;_G._DrumPremium=true
                ks.Text="✅ Unlocked! Reloading...";ks.TextColor3=Color3.fromRGB(80,255,80)
                task.wait(1);kd:Destroy();stop();task.wait(0.1)
                if gui then gui:Destroy() end;loadMain()
            else ks.Text="❌ Invalid!";ks.TextColor3=Color3.fromRGB(255,70,70) end
        end)
        kc.MouseButton1Click:Connect(function()kd:Destroy()end)
    end

    -- ════════════════════════════════════════
    -- CONNECTIONS
    -- ════════════════════════════════════════
    togBtn.MouseButton1Click:Connect(toggle)
    patBtn.MouseButton1Click:Connect(cyclePattern)
    spdBtn.MouseButton1Click:Connect(cycleSpeed)
    keyBtn.MouseButton1Click:Connect(showKeyPopup)

    sitBtn.MouseButton1Click:Connect(function()
        local ok,msg=autoSit()
        pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{
            Title=ok and "🪑 Seated!" or "🪑 Auto-Sit",
            Text=msg,Duration=2})end)
    end)

    afkBtn.MouseButton1Click:Connect(function()
        antiAfk=not antiAfk;refresh()
    end)

    shufBtn.MouseButton1Click:Connect(function()
        if not isPremium then
            shufBtn.Text="🔒";task.wait(0.5);refresh();return
        end
        shuffleOn=not shuffleOn;refresh()
    end)

    nextBtn.MouseButton1Click:Connect(function()
        if not isPremium then
            nextBtn.Text="🔒";task.wait(0.5);refresh();return
        end
        autoNextOn=not autoNextOn;refresh()
    end)

    minBtn.MouseButton1Click:Connect(function()
        guiOpen=not guiOpen;mf.Visible=guiOpen;miniBtn.Visible=not guiOpen
    end)
    miniBtn.MouseButton1Click:Connect(function()
        guiOpen=not guiOpen;mf.Visible=guiOpen;miniBtn.Visible=not guiOpen
    end)

    clsBtn.MouseButton1Click:Connect(function()
        stop();task.wait(0.1);if gui then gui:Destroy() end
        if kConn then kConn:Disconnect() end;_G._AD=nil
        print("[AutoDrum] 🗑️ Unloaded.")
    end)

    -- Song buttons
    for i,btn in ipairs(qBtns) do
        btn.MouseButton1Click:Connect(function()
            local locked=not isPremium and not isSongFree(i)
            if locked then
                midiLbl.Text="🔒 Premium! Tap 🔑"
                midiLbl.TextColor3=Color3.fromRGB(255,180,40);return
            end
            activeSongIdx=i
            doLoadMidi(PRESETS[i].url,PRESETS[i].name)
        end)
    end

    -- Filter buttons
    for i,fb in ipairs(filterBtns) do
        fb.MouseButton1Click:Connect(function()applyFilter2(FILTERS[i])end)
    end

    -- Custom load
    loadBtn.MouseButton1Click:Connect(function()
        if not isPremium and customLoads>=1 then
            midiLbl.Text="🔒 Free limit! Tap 🔑"
            midiLbl.TextColor3=Color3.fromRGB(255,130,40);return
        end
        local url=urlBox.Text:match("^%s*(.-)%s*$")
        if url and url~="" then
            customLoads=customLoads+1;activeSongIdx=nil
            doLoadMidi(url,url:match("([^/]+)%.mid") or "Custom")
        else midiLbl.Text="⚠ Paste URL!";midiLbl.TextColor3=Color3.fromRGB(255,180,40) end
    end)

    -- Keyboard P
    kConn=UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==Enum.KeyCode.P then toggle() end
    end)

    -- Mini pulse animation
    task.spawn(function()
        local p=0;while gui and gui.Parent do
            if not guiOpen and _G._AD then p=p+1
                miniSt.Color=Color3.fromRGB(255,math.floor(150+100*math.sin(p*0.3)),0)
                miniBtn.BackgroundTransparency=0.1+0.12*math.sin(p*0.5)
            else miniSt.Color=Color3.fromRGB(255,160,0);miniBtn.BackgroundTransparency=0.04 end
            task.wait(0.1)
        end
    end)

    -- ════════════════════════════════════════
    -- STARTUP
    -- ════════════════════════════════════════
    applyFilter2("All")
    refresh()
    pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{
        Title="🥁 Auto Drum [Reworked] "..(isPremium and "⭐" or "🆓"),
        Text=(isPremium and "Premium Active!" or "Free Mode").." · v7.0 · Tap ▶",
        Duration=4})end)
    print("═══════════════════════════════════════════════════")
    print("  🥁 AUTO DRUM [REWORKED] v7.0 ✅")
    print("  Mode: "..(isPremium and "⭐ PREMIUM" or "🆓 FREE"))
    print("  ├─ "..#PRESETS.." Songs │ Speed │ Anti-AFK")
    print("  ├─ Shuffle │ Auto-Next │ Progress Bar")
    print("  ├─ Artist Filter │ Auto-Sit │ Live Stats")
    print("  └─ Press P or tap ▶ to start")
    print("═══════════════════════════════════════════════════")
end

-- ════════════════════════════════════════════
-- §17  ENTRY POINT
-- ════════════════════════════════════════════
if _G._DrumValidated then
    isPremium=_G._DrumPremium or false
    loadMain()
else
    showKeyGUI(function()loadMain()end)
end
