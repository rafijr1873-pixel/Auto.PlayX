-- Actual keys (for distribution):
-- 1. AUTODRUM-VIP-2024
-- 2. JOEY-JORDISON-666
-- 3. MAGGOT-PREMIUM-X
-- 4. RAFI-DRUMS-PRO
-- 5. METAL-FOREVER-99

local function checkKey(input)
    local k = input:upper():gsub("%s+","")
    for _,v in ipairs(_KEYS) do
        if k == v then return true end
    end
    return false
end

local isPremium = _G._DrumPremium or false
local FREE_SONGS = {1, 8, 9} -- Eyeless, Duality, Before I Forget

local function isSongFree(idx)
    for _,v in ipairs(FREE_SONGS) do
        if v == idx then return true end
    end
    return false
end

