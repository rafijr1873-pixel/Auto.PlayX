-- ════════════════════════════════════════════
-- §13  KEY SYSTEM GUI
-- ════════════════════════════════════════════
local function showKeyGUI(onComplete)
    local kg = Instance.new("ScreenGui")
    kg.Name="DrumKeyGUI"; kg.ResetOnSpawn=false
    kg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; kg.Parent=pgui

    -- Overlay
    local bg=Instance.new("Frame",kg)
    bg.Size=UDim2.new(1,0,1,0)
    bg.BackgroundColor3=Color3.fromRGB(0,0,0); bg.BackgroundTransparency=0.35
    bg.BorderSizePixel=0

    -- Card
    local card=Instance.new("Frame",bg)
    card.Size=UDim2.new(0,295,0,400)
    card.Position=UDim2.new(0.5,-148,0.5,-200)
    card.BackgroundColor3=Color3.fromRGB(12,12,24)
    card.BorderSizePixel=0; card.Active=true; card.Draggable=true
    Instance.new("UICorner",card).CornerRadius=UDim.new(0,14)
    local cs=Instance.new("UIStroke",card)
    cs.Color=Color3.fromRGB(255,170,0); cs.Thickness=2

    -- Title
    local t1=Instance.new("TextLabel",card)
    t1.Size=UDim2.new(1,0,0,28); t1.Position=UDim2.new(0,0,0,14)
    t1.BackgroundTransparency=1; t1.Text="🥁 FREEMIUM AUTO PLAY"
    t1.TextColor3=Color3.fromRGB(255,210,50)
    t1.TextSize=18; t1.Font=Enum.Font.GothamBold

    local t2=Instance.new("TextLabel",card)
    t2.Size=UDim2.new(1,0,0,18); t2.Position=UDim2.new(0,0,0,42)
    t2.BackgroundTransparency=1; t2.Text="Virtual Drums Auto Player · v6.0"
    t2.TextColor3=Color3.fromRGB(160,160,180)
    t2.TextSize=11; t2.Font=Enum.Font.Gotham

    -- Divider
    local dv=Instance.new("Frame",card)
    dv.Size=UDim2.new(0.85,0,0,1); dv.Position=UDim2.new(0.075,0,0,68)
    dv.BackgroundColor3=Color3.fromRGB(60,60,90); dv.BorderSizePixel=0

    -- Feature Comparison
    local function featureLbl(txt,y,col)
        local l=Instance.new("TextLabel",card)
        l.Size=UDim2.new(1,-30,0,15); l.Position=UDim2.new(0,15,0,y)
        l.BackgroundTransparency=1; l.Text=txt
        l.TextColor3=col; l.TextSize=11; l.Font=Enum.Font.Gotham
        l.TextXAlignment=Enum.TextXAlignment.Left; return l
    end

    local hdr1=Instance.new("TextLabel",card)
    hdr1.Size=UDim2.new(0.45,0,0,20); hdr1.Position=UDim2.new(0.03,0,0,76)
    hdr1.BackgroundTransparency=1; hdr1.Text="🆓 FREE"
    hdr1.TextColor3=Color3.fromRGB(180,180,180)
    hdr1.TextSize=12; hdr1.Font=Enum.Font.GothamBold
    hdr1.TextXAlignment=Enum.TextXAlignment.Center

    local hdr2=Instance.new("TextLabel",card)
    hdr2.Size=UDim2.new(0.45,0,0,20); hdr2.Position=UDim2.new(0.52,0,0,76)
    hdr2.BackgroundTransparency=1; hdr2.Text="⭐ PREMIUM"
    hdr2.TextColor3=Color3.fromRGB(255,200,50)
    hdr2.TextSize=12; hdr2.Font=Enum.Font.GothamBold
    hdr2.TextXAlignment=Enum.TextXAlignment.Center

    -- FREE column
    local freeItems = {
        {y=100, txt="✅ Rock Beat", col=Color3.fromRGB(120,220,120)},
        {y=117, txt="✅ 3 MIDI Songs", col=Color3.fromRGB(120,220,120)},
        {y=134, txt="✅ 1 Custom Load", col=Color3.fromRGB(120,220,120)},
        {y=151, txt="❌ Eyeless Pattern", col=Color3.fromRGB(255,90,90)},
        {y=168, txt="❌ 8 Locked Songs", col=Color3.fromRGB(255,90,90)},
        {y=185, txt="❌ Unlimited Load", col=Color3.fromRGB(255,90,90)},
    }
    for _,item in ipairs(freeItems) do
        local l=Instance.new("TextLabel",card)
        l.Size=UDim2.new(0.45,0,0,14); l.Position=UDim2.new(0.03,0,0,item.y)
        l.BackgroundTransparency=1; l.Text=item.txt
        l.TextColor3=item.col; l.TextSize=9; l.Font=Enum.Font.Gotham
        l.TextXAlignment=Enum.TextXAlignment.Center
    end

    -- PREMIUM column
    local premItems = {
        {y=100, txt="✅ Rock Beat"},
        {y=117, txt="✅ 11 MIDI Songs"},
        {y=134, txt="✅ Unlimited Loads"},
        {y=151, txt="✅ Eyeless Pattern"},
        {y=168, txt="✅ All Songs"},
        {y=185, txt="✅ Full Features"},
    }
    for _,item in ipairs(premItems) do
        local l=Instance.new("TextLabel",card)
        l.Size=UDim2.new(0.45,0,0,14); l.Position=UDim2.new(0.52,0,0,item.y)
        l.BackgroundTransparency=1; l.Text=item.txt
        l.TextColor3=Color3.fromRGB(120,255,120)
        l.TextSize=9; l.Font=Enum.Font.Gotham
        l.TextXAlignment=Enum.TextXAlignment.Center
    end

    -- Free songs list
    local fsLbl=Instance.new("TextLabel",card)
    fsLbl.Size=UDim2.new(1,-30,0,14); fsLbl.Position=UDim2.new(0,15,0,208)
    fsLbl.BackgroundTransparency=1
    fsLbl.Text="🆓 Free Songs: Eyeless · Duality · Before I Forget"
    fsLbl.TextColor3=Color3.fromRGB(140,140,160)
    fsLbl.TextSize=9; fsLbl.Font=Enum.Font.Gotham

    -- Divider 2
    local dv2=Instance.new("Frame",card)
    dv2.Size=UDim2.new(0.85,0,0,1); dv2.Position=UDim2.new(0.075,0,0,230)
    dv2.BackgroundColor3=Color3.fromRGB(60,60,90); dv2.BorderSizePixel=0

    -- Key Input
    local keyLbl=Instance.new("TextLabel",card)
    keyLbl.Size=UDim2.new(1,0,0,18); keyLbl.Position=UDim2.new(0,0,0,238)
    keyLbl.BackgroundTransparency=1; keyLbl.Text="🔑 Enter Premium Key"
    keyLbl.TextColor3=Color3.fromRGB(200,200,220)
    keyLbl.TextSize=12; keyLbl.Font=Enum.Font.GothamBold

    local keyBox=Instance.new("TextBox",card)
    keyBox.Size=UDim2.new(0.85,0,0,34)
    keyBox.Position=UDim2.new(0.075,0,0,260)
    keyBox.BackgroundColor3=Color3.fromRGB(22,22,42)
    keyBox.BorderSizePixel=0; keyBox.Text=""
    keyBox.PlaceholderText="  XXXXX-XXXXX-XXXXX"
    keyBox.PlaceholderColor3=Color3.fromRGB(70,70,100)
    keyBox.TextColor3=Color3.fromRGB(255,220,100)
    keyBox.TextSize=14; keyBox.Font=Enum.Font.GothamBold
    keyBox.ClearTextOnFocus=false
    Instance.new("UICorner",keyBox).CornerRadius=UDim.new(0,8)
    Instance.new("UIStroke",keyBox).Color=Color3.fromRGB(80,80,130)
    Instance.new("UIPadding",keyBox).PaddingLeft=UDim.new(0,8)

    -- Unlock Button (Gold)
    local unlockBtn=Instance.new("TextButton",card)
    unlockBtn.Size=UDim2.new(0.42,0,0,36)
    unlockBtn.Position=UDim2.new(0.04,0,0,304)
    unlockBtn.BackgroundColor3=Color3.fromRGB(200,160,20)
    unlockBtn.Text="🔓 UNLOCK"
    unlockBtn.TextColor3=Color3.fromRGB(20,20,10)
    unlockBtn.TextSize=14; unlockBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",unlockBtn).CornerRadius=UDim.new(0,9)

    -- Free Mode Button (Gray)
    local freeBtn=Instance.new("TextButton",card)
    freeBtn.Size=UDim2.new(0.42,0,0,36)
    freeBtn.Position=UDim2.new(0.54,0,0,304)
    freeBtn.BackgroundColor3=Color3.fromRGB(55,55,75)
    freeBtn.Text="▶ FREE MODE"
    freeBtn.TextColor3=Color3.fromRGB(180,180,200)
    freeBtn.TextSize=12; freeBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",freeBtn).CornerRadius=UDim.new(0,9)

    -- Status
    local statLbl=Instance.new("TextLabel",card)
    statLbl.Size=UDim2.new(1,-20,0,18)
    statLbl.Position=UDim2.new(0,10,0,348)
    statLbl.BackgroundTransparency=1
    statLbl.Text="Enter key or continue free"
    statLbl.TextColor3=Color3.fromRGB(120,120,140)
    statLbl.TextSize=10; statLbl.Font=Enum.Font.Gotham

    -- Credits
    local credLbl=Instance.new("TextLabel",card)
    credLbl.Size=UDim2.new(1,0,0,16)
    credLbl.Position=UDim2.new(0,0,0,374)
    credLbl.BackgroundTransparency=1
    credLbl.Text="by rafijr1873 · Virtual Drums"
    credLbl.TextColor3=Color3.fromRGB(70,70,90)
    credLbl.TextSize=9; credLbl.Font=Enum.Font.Gotham

    -- ── BUTTON LOGIC ──

    unlockBtn.MouseButton1Click:Connect(function()
        local input = keyBox.Text
        if input == "" then
            statLbl.Text = "⚠ Please enter a key!"
            statLbl.TextColor3 = Color3.fromRGB(255,180,40)
            return
        end

        statLbl.Text = "⏳ Validating..."
        statLbl.TextColor3 = Color3.fromRGB(200,200,100)
        task.wait(0.5)

        if checkKey(input) then
            -- SUCCESS
            isPremium = true
            _G._DrumPremium = true
            _G._DrumValidated = true

            statLbl.Text = "✅ PREMIUM UNLOCKED!"
            statLbl.TextColor3 = Color3.fromRGB(80,255,80)
            unlockBtn.BackgroundColor3 = Color3.fromRGB(50,200,50)
            unlockBtn.Text = "✅ SUCCESS"

            cs.Color = Color3.fromRGB(80,255,80)
            keyBox.TextColor3 = Color3.fromRGB(80,255,80)

            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title="⭐ PREMIUM UNLOCKED!",
                    Text="All 11 songs + full features activated!",
                    Duration=4
                })
            end)

            task.wait(1.2)
            kg:Destroy()
            onComplete()
        else
            -- INVALID
            statLbl.Text = "❌ Invalid key! Try again"
            statLbl.TextColor3 = Color3.fromRGB(255,70,70)
            keyBox.TextColor3 = Color3.fromRGB(255,70,70)
            cs.Color = Color3.fromRGB(255,70,70)

            task.wait(1)
            keyBox.TextColor3 = Color3.fromRGB(255,220,100)
            cs.Color = Color3.fromRGB(255,170,0)
        end
    end)

    freeBtn.MouseButton1Click:Connect(function()
        isPremium = false
        _G._DrumPremium = false
        _G._DrumValidated = true

        statLbl.Text = "▶ Loading Free Mode..."
        statLbl.TextColor3 = Color3.fromRGB(150,200,255)

        task.wait(0.6)
        kg:Destroy()
        onComplete()
    end)
end

