-- §14  MAIN SCRIPT LOADER
-- ════════════════════════════════════════════
local function loadMainScript()

    -- ── GUI ──
    gui = Instance.new("ScreenGui")
    gui.Name="DrumGUI"; gui.ResetOnSpawn=false
    gui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; gui.Parent=pgui

    -- Mini Button
    miniBtn=Instance.new("TextButton",gui)
    miniBtn.Size=UDim2.new(0,46,0,46)
    miniBtn.Position=UDim2.new(0,6,0.5,-23)
    miniBtn.BackgroundColor3=Color3.fromRGB(18,18,32)
    miniBtn.BackgroundTransparency=0.04
    miniBtn.Text="🥁"; miniBtn.TextSize=24
    miniBtn.Font=Enum.Font.GothamBold
    miniBtn.TextColor3=Color3.fromRGB(255,200,50)
    miniBtn.Visible=false; miniBtn.ZIndex=10
    Instance.new("UICorner",miniBtn).CornerRadius=UDim.new(0,23)
    local miniSt=Instance.new("UIStroke",miniBtn)
    miniSt.Color=Color3.fromRGB(255,160,0); miniSt.Thickness=2

    -- Main Frame
    mainFrame=Instance.new("Frame",gui)
    mainFrame.Name="Main"
    mainFrame.Size=UDim2.new(0,262,0,400)
    mainFrame.Position=UDim2.new(0.5,-131,0,6)
    mainFrame.BackgroundColor3=Color3.fromRGB(12,12,22)
    mainFrame.BackgroundTransparency=0.02
    mainFrame.BorderSizePixel=0; mainFrame.Active=true; mainFrame.Draggable=true
    Instance.new("UICorner",mainFrame).CornerRadius=UDim.new(0,12)
    local frs=Instance.new("UIStroke",mainFrame)
    frs.Color=isPremium and Color3.fromRGB(255,200,50) or Color3.fromRGB(120,120,150)
    frs.Thickness=1.6

    -- Title Bar
    local tBar=Instance.new("Frame",mainFrame)
    tBar.Size=UDim2.new(1,0,0,32)
    tBar.BackgroundColor3=Color3.fromRGB(20,20,38)
    tBar.BackgroundTransparency=0.1; tBar.BorderSizePixel=0
    Instance.new("UICorner",tBar).CornerRadius=UDim.new(0,12)

    local badge = isPremium and "⭐" or "🆓"
    local badgeCol = isPremium and Color3.fromRGB(255,200,50) or Color3.fromRGB(160,160,180)

    local tLbl=Instance.new("TextLabel",tBar)
    tLbl.Size=UDim2.new(1,-68,1,0); tLbl.Position=UDim2.new(0,10,0,0)
    tLbl.BackgroundTransparency=1
    tLbl.Text=badge.." Freemium AutoPlay"
    tLbl.TextColor3=badgeCol
    tLbl.TextSize=12; tLbl.Font=Enum.Font.GothamBold
    tLbl.TextXAlignment=Enum.TextXAlignment.Left

    -- 🔑 Key button (upgrade from free)
    local keyBtn=Instance.new("TextButton",tBar)
    keyBtn.Size=UDim2.new(0,22,0,22); keyBtn.Position=UDim2.new(1,-82,0,5)
    keyBtn.BackgroundColor3=isPremium and Color3.fromRGB(50,120,50) or Color3.fromRGB(180,140,20)
    keyBtn.BackgroundTransparency=0.15
    keyBtn.Text="🔑"; keyBtn.TextSize=11; keyBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",keyBtn).CornerRadius=UDim.new(0,6)

    local minBtn=Instance.new("TextButton",tBar)
    minBtn.Size=UDim2.new(0,22,0,22); minBtn.Position=UDim2.new(1,-56,0,5)
    minBtn.BackgroundColor3=Color3.fromRGB(55,55,95)
    minBtn.BackgroundTransparency=0.15; minBtn.Text="▬"
    minBtn.TextColor3=Color3.new(1,1,1); minBtn.TextSize=11
    minBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",minBtn).CornerRadius=UDim.new(0,6)

    local clsBtn=Instance.new("TextButton",tBar)
    clsBtn.Size=UDim2.new(0,22,0,22); clsBtn.Position=UDim2.new(1,-30,0,5)
    clsBtn.BackgroundColor3=Color3.fromRGB(150,28,28)
    clsBtn.BackgroundTransparency=0.12; clsBtn.Text="✕"
    clsBtn.TextColor3=Color3.new(1,1,1); clsBtn.TextSize=11
    clsBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",clsBtn).CornerRadius=UDim.new(0,6)

    -- Row 1: Play + Pattern
    togBtn=Instance.new("TextButton",mainFrame)
    togBtn.Size=UDim2.new(0,115,0,32)
    togBtn.Position=UDim2.new(0,8,0,38)
    togBtn.BackgroundColor3=Color3.fromRGB(0,155,50)
    togBtn.Text="▶  PLAY"; togBtn.TextColor3=Color3.new(1,1,1)
    togBtn.TextSize=14; togBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",togBtn).CornerRadius=UDim.new(0,9)

    patBtn=Instance.new("TextButton",mainFrame)
    patBtn.Size=UDim2.new(0,122,0,32)
    patBtn.Position=UDim2.new(0,130,0,38)
    patBtn.BackgroundColor3=Color3.fromRGB(42,42,72)
    patBtn.Text="Rock  ▸"; patBtn.TextColor3=Color3.fromRGB(195,195,255)
    patBtn.TextSize=12; patBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",patBtn).CornerRadius=UDim.new(0,9)

    -- Quick MIDI header
    local freeC = isPremium and #PRESETS or #FREE_SONGS
    local div1=Instance.new("TextLabel",mainFrame)
    div1.Size=UDim2.new(1,-16,0,16); div1.Position=UDim2.new(0,8,0,76)
    div1.BackgroundTransparency=1
    div1.Text=isPremium and "── ⭐ ALL SONGS ("..#PRESETS..") ──" or "── 🆓 SONGS (3 free / "..#PRESETS.." total) ──"
    div1.TextColor3=isPremium and Color3.fromRGB(255,200,50) or Color3.fromRGB(180,180,200)
    div1.TextSize=9; div1.Font=Enum.Font.GothamBold

    -- Scrollable song list
    local scroll=Instance.new("ScrollingFrame",mainFrame)
    scroll.Size=UDim2.new(1,-12,0,150)
    scroll.Position=UDim2.new(0,6,0,94)
    scroll.BackgroundColor3=Color3.fromRGB(16,16,28)
    scroll.BackgroundTransparency=0.3; scroll.BorderSizePixel=0
    scroll.ScrollBarThickness=4
    scroll.ScrollBarImageColor3=Color3.fromRGB(255,180,50)
    scroll.ScrollBarImageTransparency=0.3
    scroll.AutomaticCanvasSize=Enum.AutomaticSize.Y
    scroll.ScrollingDirection=Enum.ScrollingDirection.Y
    scroll.ElasticBehavior=Enum.ElasticBehavior.Always
    Instance.new("UICorner",scroll).CornerRadius=UDim.new(0,8)

    local grid=Instance.new("UIGridLayout",scroll)
    grid.CellSize=UDim2.new(0,118,0,36)
    grid.CellPadding=UDim2.new(0,4,0,4)
    grid.FillDirection=Enum.FillDirection.Horizontal
    grid.HorizontalAlignment=Enum.HorizontalAlignment.Center
    grid.SortOrder=Enum.SortOrder.LayoutOrder
    local gp=Instance.new("UIPadding",scroll)
    gp.PaddingTop=UDim.new(0,4); gp.PaddingBottom=UDim.new(0,4)
    gp.PaddingLeft=UDim.new(0,2); gp.PaddingRight=UDim.new(0,2)

    -- Song Buttons
    qBtns = {}
    for i, preset in ipairs(PRESETS) do
        local free = isSongFree(i)
        local locked = not isPremium and not free

        local btn=Instance.new("TextButton",scroll)
        btn.Name="S"..i; btn.LayoutOrder=i
        btn.BackgroundColor3=locked and Color3.fromRGB(35,35,45) or preset.color
        btn.BackgroundTransparency=locked and 0.3 or 0.12
        btn.Text=locked and "🔒 "..preset.name or preset.name
        btn.TextColor3=locked and Color3.fromRGB(100,100,110) or Color3.new(1,1,1)
        btn.TextSize=10; btn.Font=Enum.Font.GothamBold
        btn.TextTruncate=Enum.TextTruncate.AtEnd
        btn.TextYAlignment=Enum.TextYAlignment.Top
        btn.Active=not locked
        Instance.new("UICorner",btn).CornerRadius=UDim.new(0,7)
        Instance.new("UIPadding",btn).PaddingTop=UDim.new(0,4)

        local sub=Instance.new("TextLabel",btn)
        sub.Size=UDim2.new(1,-6,0,11); sub.Position=UDim2.new(0,3,1,-14)
        sub.BackgroundTransparency=1
        sub.Text=locked and "Premium Only" or preset.artist
        sub.TextColor3=locked and Color3.fromRGB(80,80,90) or Color3.fromRGB(210,210,210)
        sub.TextTransparency=0.35; sub.TextSize=8; sub.Font=Enum.Font.Gotham

        qBtns[i]=btn
    end

    -- Scroll hint
    local sHint=Instance.new("TextLabel",mainFrame)
    sHint.Size=UDim2.new(1,-16,0,12); sHint.Position=UDim2.new(0,8,0,246)
    sHint.BackgroundTransparency=1; sHint.Text="↕ scroll for more"
    sHint.TextColor3=Color3.fromRGB(70,70,90); sHint.TextSize=8; sHint.Font=Enum.Font.Gotham

    -- Custom MIDI section
    local div2=Instance.new("TextLabel",mainFrame)
    div2.Size=UDim2.new(1,-16,0,16); div2.Position=UDim2.new(0,8,0,260)
    div2.BackgroundTransparency=1; div2.Text="── 🔗 CUSTOM MIDI ──"
    div2.TextColor3=Color3.fromRGB(100,160,255)
    div2.TextSize=9; div2.Font=Enum.Font.GothamBold

    urlBox=Instance.new("TextBox",mainFrame)
    urlBox.Size=UDim2.new(1,-16,0,26); urlBox.Position=UDim2.new(0,8,0,278)
    urlBox.BackgroundColor3=Color3.fromRGB(20,20,40)
    urlBox.BackgroundTransparency=0.05; urlBox.BorderSizePixel=0
    urlBox.Text=""; urlBox.PlaceholderText="  Paste .mid URL here..."
    urlBox.PlaceholderColor3=Color3.fromRGB(65,65,95)
    urlBox.TextColor3=Color3.fromRGB(200,210,255)
    urlBox.TextSize=9; urlBox.Font=Enum.Font.Gotham
    urlBox.ClearTextOnFocus=false; urlBox.TextXAlignment=Enum.TextXAlignment.Left
    urlBox.TextTruncate=Enum.TextTruncate.AtEnd
    Instance.new("UICorner",urlBox).CornerRadius=UDim.new(0,7)
    Instance.new("UIStroke",urlBox).Color=Color3.fromRGB(55,55,90)
    Instance.new("UIPadding",urlBox).PaddingLeft=UDim.new(0,6)

    loadBtn=Instance.new("TextButton",mainFrame)
    loadBtn.Size=UDim2.new(0,82,0,22); loadBtn.Position=UDim2.new(0,8,0,308)
    loadBtn.BackgroundColor3=Color3.fromRGB(50,50,110)
    loadBtn.Text="📥 LOAD"; loadBtn.TextColor3=Color3.new(1,1,1)
    loadBtn.TextSize=10; loadBtn.Font=Enum.Font.GothamBold
    Instance.new("UICorner",loadBtn).CornerRadius=UDim.new(0,7)

    midiLbl=Instance.new("TextLabel",mainFrame)
    midiLbl.Size=UDim2.new(0,155,0,22); midiLbl.Position=UDim2.new(0,96,0,308)
    midiLbl.BackgroundTransparency=1; midiLbl.Text="No MIDI loaded"
    midiLbl.TextColor3=Color3.fromRGB(90,90,105)
    midiLbl.TextSize=9; midiLbl.Font=Enum.Font.Gotham
    midiLbl.TextXAlignment=Enum.TextXAlignment.Left
    midiLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- Status
    s1=Instance.new("TextLabel",mainFrame)
    s1.Size=UDim2.new(1,-16,0,16); s1.Position=UDim2.new(0,8,0,338)
    s1.BackgroundTransparency=1; s1.Text="⏹ Rock · 120 BPM"
    s1.TextColor3=Color3.fromRGB(130,130,130)
    s1.TextSize=12; s1.Font=Enum.Font.GothamBold

    s2=Instance.new("TextLabel",mainFrame)
    s2.Size=UDim2.new(1,-16,0,14); s2.Position=UDim2.new(0,8,0,356)
    s2.BackgroundTransparency=1; s2.Text="Bar: 0  │  Tap ▶ or P"
    s2.TextColor3=Color3.fromRGB(90,90,105)
    s2.TextSize=9; s2.Font=Enum.Font.Gotham

    npLbl=Instance.new("TextLabel",mainFrame)
    npLbl.Size=UDim2.new(1,-16,0,14); npLbl.Position=UDim2.new(0,8,0,372)
    npLbl.BackgroundTransparency=1; npLbl.Text=""
    npLbl.TextColor3=Color3.fromRGB(255,200,60); npLbl.TextTransparency=0.15
    npLbl.TextSize=9; npLbl.Font=Enum.Font.GothamBold
    npLbl.TextTruncate=Enum.TextTruncate.AtEnd

    -- Tier badge at bottom
    local tierLbl=Instance.new("TextLabel",mainFrame)
    tierLbl.Size=UDim2.new(1,-16,0,12); tierLbl.Position=UDim2.new(0,8,0,388)
    tierLbl.BackgroundTransparency=1
    tierLbl.Text=isPremium and "⭐ PREMIUM ACTIVE" or "🆓 FREE MODE · 🔑 tap key to upgrade"
    tierLbl.TextColor3=isPremium and Color3.fromRGB(255,200,50) or Color3.fromRGB(100,100,120)
    tierLbl.TextSize=8; tierLbl.Font=Enum.Font.Gotham

    -- ── SECTION COLORS ──
    local SC={
        ["Rock"]=Color3.fromRGB(100,220,130),
        ["⚡ INTRO"]=Color3.fromRGB(160,160,160),
        ["♫ VERSE"]=Color3.fromRGB(100,200,255),
        ["♫ VRS.2"]=Color3.fromRGB(80,180,230),
        ["⬆ PRE-CH"]=Color3.fromRGB(255,200,80),
        ["⬆ PRE-C2"]=Color3.fromRGB(255,220,60),
        ["★ CHORUS"]=Color3.fromRGB(255,120,40),
        ["★ CHOR.2"]=Color3.fromRGB(255,80,20),
        ["⬛ BREAK"]=Color3.fromRGB(180,80,255),
        ["‼ BLAST"]=Color3.fromRGB(255,40,40),
        ["↓ FILL"]=Color3.fromRGB(255,220,60),
        ["→ LOOP"]=Color3.fromRGB(120,255,120),
        ["NO MIDI"]=Color3.fromRGB(255,80,80),
        ["↻ LOOP"]=Color3.fromRGB(120,255,180),
        ["IDLE"]=Color3.fromRGB(130,130,130),
    }

    -- ── HIGHLIGHT FUNCS ──
    clearHL = function()
        for i,btn in ipairs(qBtns) do
            local locked = not isPremium and not isSongFree(i)
            btn.BackgroundTransparency = locked and 0.3 or 0.12
            for _,c in ipairs(btn:GetChildren()) do
                if c:IsA("UIStroke") then c:Destroy() end
            end
        end
    end

    highlightSong = function(name)
        clearHL()
        for i,btn in ipairs(qBtns) do
            if PRESETS[i].name==name then
                btn.BackgroundTransparency=0
                local st=Instance.new("UIStroke",btn)
                st.Color=Color3.fromRGB(255,255,100); st.Thickness=2
            end
        end
    end

    -- ── REFRESH ──
    refresh = function()
        local p=PATS[pIdx]; patBtn.Text=p.name.."  ▸"
        if _G._AD then
            togBtn.Text="⏸  STOP"; togBtn.BackgroundColor3=Color3.fromRGB(175,28,28)
        else
            togBtn.Text="▶  PLAY"; togBtn.BackgroundColor3=Color3.fromRGB(0,155,50)
        end
        local bStr=(p.name=="MIDI" and midiObj) and tostring(midiObj.bpm) or (p.name=="MIDI" and "---" or tostring(p.bpm))
        if _G._AD then
            s1.Text=secN.." · "..bStr.." BPM"
            s1.TextColor3=SC[secN] or Color3.fromRGB(80,255,90)
            s2.Text="Bar: "..barN.."  │  🟢 Playing"
            s2.TextColor3=Color3.fromRGB(60,185,60)
        else
            s1.Text="⏹ "..p.name.." · "..bStr.." BPM"
            s1.TextColor3=Color3.fromRGB(130,130,130)
            s2.Text="Bar: "..barN.."  │  Tap ▶ or P"
            s2.TextColor3=Color3.fromRGB(90,90,105)
        end
        if midiObj and not midiLoading then
            midiLbl.Text="✅ "..midiObj.noteCount.."n · "..string.format("%.0fs",midiObj.duration).." · "..midiObj.bpm.."BPM"
            midiLbl.TextColor3=Color3.fromRGB(80,255,80)
        elseif not midiLoading then
            midiLbl.Text="No MIDI loaded"; midiLbl.TextColor3=Color3.fromRGB(90,90,105)
        end
        npLbl.Text=currentSong~="" and ("♪ Now: "..currentSong) or ""
    end

    task.spawn(function()
        while gui and gui.Parent do pcall(refresh); task.wait(0.25) end
    end)

    -- ── TOGGLE / CYCLE ──
    local function toggle()
        if _G._AD then stop() else go() end; refresh()
    end

    local function cycle()
        local was=_G._AD; if was then stop(); task.wait(0.15) end
        -- Cycle logic with premium check
        local next = pIdx + 1
        if next > 2 then next = 1 end
        -- Skip Eyeless pattern if free
        if PATS[next].premium and not isPremium then
            next = 1
        end
        pIdx = next
        barN=0; introD=true; secN="IDLE"; currentSong=""
        clearHL(); refresh()
        if was then go(); refresh() end
    end

    -- ── MIDI LOADER ──
    doLoadMidi = function(url, songName)
        if midiLoading then return end
        midiLoading=true; local was=_G._AD
        if was then stop(); task.wait(0.15) end
        loadBtn.Text="⏳..."; loadBtn.BackgroundColor3=Color3.fromRGB(80,80,40)
        highlightSong(songName)
        task.spawn(function()
            local data,err=loadMidi(url,function(msg)
                midiLbl.Text=msg; midiLbl.TextColor3=Color3.fromRGB(255,200,60)
            end)
            midiLoading=false; loadBtn.Text="📥 LOAD"
            loadBtn.BackgroundColor3=Color3.fromRGB(50,50,110)
            if data then
                midiObj=data; currentSong=songName or "Custom"
                pIdx=3; barN=0; secN="IDLE"
                highlightSong(songName); refresh()
                task.wait(0.2)
                if not _G._AD then go(); refresh() end
                pcall(function()
                    game:GetService("StarterGui"):SetCore("SendNotification",{
                        Title="🥁 "..currentSong,
                        Text=data.noteCount.." notes · "..data.bpm.." BPM",
                        Duration=3})
                end)
            else
                midiLbl.Text="❌ "..tostring(err):sub(1,28)
                midiLbl.TextColor3=Color3.fromRGB(255,70,70); clearHL()
            end
        end)
    end

    -- ── GUI TOGGLE ──
    local function toggleGUI()
        guiOpen=not guiOpen
        mainFrame.Visible=guiOpen; miniBtn.Visible=not guiOpen
    end

    -- ── KEY UPGRADE (in-app) ──
    local function showInAppKey()
        if isPremium then
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification",{
                    Title="⭐ Already Premium!",Text="All features unlocked.",Duration=3})
            end)
            return
        end
        -- Create mini key dialog
        local kd=Instance.new("Frame",gui)
        kd.Size=UDim2.new(0,240,0,120); kd.Position=UDim2.new(0.5,-120,0.4,-60)
        kd.BackgroundColor3=Color3.fromRGB(16,16,30); kd.BorderSizePixel=0
        kd.Active=true; kd.Draggable=true; kd.ZIndex=20
        Instance.new("UICorner",kd).CornerRadius=UDim.new(0,10)
        Instance.new("UIStroke",kd).Color=Color3.fromRGB(255,180,0)

        local kl=Instance.new("TextLabel",kd)
        kl.Size=UDim2.new(1,0,0,22); kl.Position=UDim2.new(0,0,0,8)
        kl.BackgroundTransparency=1; kl.Text="🔑 Enter Premium Key"
        kl.TextColor3=Color3.fromRGB(255,200,50); kl.TextSize=13; kl.Font=Enum.Font.GothamBold

        local kb=Instance.new("TextBox",kd)
        kb.Size=UDim2.new(0.85,0,0,28); kb.Position=UDim2.new(0.075,0,0,36)
        kb.BackgroundColor3=Color3.fromRGB(25,25,48); kb.BorderSizePixel=0
        kb.Text=""; kb.PlaceholderText="  KEY-HERE"
        kb.PlaceholderColor3=Color3.fromRGB(70,70,100)
        kb.TextColor3=Color3.fromRGB(255,220,100); kb.TextSize=12; kb.Font=Enum.Font.GothamBold
        Instance.new("UICorner",kb).CornerRadius=UDim.new(0,7)
        Instance.new("UIPadding",kb).PaddingLeft=UDim.new(0,6)

        local ku=Instance.new("TextButton",kd)
        ku.Size=UDim2.new(0.4,0,0,26); ku.Position=UDim2.new(0.075,0,0,72)
        ku.BackgroundColor3=Color3.fromRGB(200,160,20); ku.Text="UNLOCK"
        ku.TextColor3=Color3.fromRGB(20,20,10); ku.TextSize=11; ku.Font=Enum.Font.GothamBold
        Instance.new("UICorner",ku).CornerRadius=UDim.new(0,7)

        local kc=Instance.new("TextButton",kd)
        kc.Size=UDim2.new(0.4,0,0,26); kc.Position=UDim2.new(0.525,0,0,72)
        kc.BackgroundColor3=Color3.fromRGB(80,30,30); kc.Text="Cancel"
        kc.TextColor3=Color3.new(1,1,1); kc.TextSize=11; kc.Font=Enum.Font.GothamBold
        Instance.new("UICorner",kc).CornerRadius=UDim.new(0,7)

        local ks=Instance.new("TextLabel",kd)
        ks.Size=UDim2.new(1,0,0,14); ks.Position=UDim2.new(0,0,0,102)
        ks.BackgroundTransparency=1; ks.Text=""
        ks.TextColor3=Color3.fromRGB(120,120,140); ks.TextSize=9; ks.Font=Enum.Font.Gotham

        ku.MouseButton1Click:Connect(function()
            if checkKey(kb.Text) then
                isPremium=true; _G._DrumPremium=true
                ks.Text="✅ Unlocked! Reloading..."
                ks.TextColor3=Color3.fromRGB(80,255,80)
                task.wait(1); kd:Destroy()
                -- Reload GUI with premium
                stop(); task.wait(0.1)
                if gui then gui:Destroy() end
                loadMainScript()
            else
                ks.Text="❌ Invalid key!"; ks.TextColor3=Color3.fromRGB(255,70,70)
            end
        end)
        kc.MouseButton1Click:Connect(function() kd:Destroy() end)
    end

    -- ── CONNECTIONS ──
    togBtn.MouseButton1Click:Connect(toggle)
    patBtn.MouseButton1Click:Connect(cycle)
    minBtn.MouseButton1Click:Connect(toggleGUI)
    miniBtn.MouseButton1Click:Connect(toggleGUI)
    keyBtn.MouseButton1Click:Connect(showInAppKey)

    clsBtn.MouseButton1Click:Connect(function()
        stop(); task.wait(0.1)
        if gui then gui:Destroy() end
        if kConn then kConn:Disconnect() end
        _G._AD=nil; print("[FreemiumDrum] 🗑️ Unloaded.")
    end)

    -- Quick MIDI buttons
    for i,btn in ipairs(qBtns) do
        btn.MouseButton1Click:Connect(function()
            local locked = not isPremium and not isSongFree(i)
            if locked then
                midiLbl.Text="🔒 Premium only! Tap 🔑"
                midiLbl.TextColor3=Color3.fromRGB(255,180,40)
                return
            end
            doLoadMidi(PRESETS[i].url, PRESETS[i].name)
        end)
    end

    -- Custom MIDI Load
    loadBtn.MouseButton1Click:Connect(function()
        if not isPremium and customLoads >= MAX_FREE_LOADS then
            midiLbl.Text="🔒 Free limit! Tap 🔑 for unlimited"
            midiLbl.TextColor3=Color3.fromRGB(255,130,40)
            return
        end
        local url=urlBox.Text:match("^%s*(.-)%s*$")
        if url and url~="" then
            customLoads=customLoads+1
            doLoadMidi(url, url:match("([^/]+)%.mid") or "Custom")
        else
            midiLbl.Text="⚠ Paste URL first!"
            midiLbl.TextColor3=Color3.fromRGB(255,180,40)
        end
    end)

    -- Keyboard P
    kConn=UIS.InputBegan:Connect(function(i,gp)
        if gp then return end
        if i.KeyCode==Enum.KeyCode.P then toggle() end
    end)

    -- Mini pulse
    task.spawn(function()
        local p=0; while gui and gui.Parent do
            if not guiOpen and _G._AD then p=p+1
                miniSt.Color=Color3.fromRGB(255,math.floor(150+100*math.sin(p*0.3)),0)
                miniBtn.BackgroundTransparency=0.15+0.15*math.sin(p*0.5)
            else miniSt.Color=Color3.fromRGB(255,160,0); miniBtn.BackgroundTransparency=0.04 end
            task.wait(0.1)
        end
    end)

    -- Startup
    refresh()
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification",{
            Title="🥁 Freemium AutoPlay "..(isPremium and "⭐" or "🆓"),
            Text=isPremium and "Premium Active! All features unlocked" or "Free Mode · 3 songs · Tap 🔑 to upgrade",
            Duration=4})
    end)
    print("══════════════════════════════════════════")
    print("  🥁 FREEMIUM AUTO PLAY v6.0 ✅")
    print("  Mode: "..(isPremium and "⭐ PREMIUM" or "🆓 FREE"))
    if isPremium then
        print("  All "..#PRESETS.." songs unlocked!")
    else
        print("  Free: Eyeless · Duality · Before I Forget")
        print("  🔑 Tap key button to unlock all!")
    end
    print("══════════════════════════════════════════")
end

-- ════════════════════════════════════════════
-- §15  ENTRY POINT
-- ════════════════════════════════════════════
if _G._DrumValidated then
    -- Already validated this session
    isPremium = _G._DrumPremium or false
    loadMainScript()
else
    -- Show Key GUI first
    showKeyGUI(function()
        loadMainScript()
    end)
end
