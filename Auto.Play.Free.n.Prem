local function eyelessLoop()
    if introD then introD=false
        if not sec("⚡ INTRO",{iA,iB,iC,iD},8,E) then return end end
    if not sec("♫ VERSE",{vA,vA,vB,vC,vA,vB,vD,vC},8,E) then return end
    if not sec("⬆ PRE-CH",{pA,pB,pF},8,E) then return end
    if not sec("★ CHORUS",{cA,cA,cB,cA,cFl},16,E) then return end
    if not sec("♫ VRS.2",{vB,vD,vC,vB},8,E) then return end
    if not sec("⬆ PRE-C2",{pB,pA,pF},8,E) then return end
    if not sec("★ CHOR.2",{cA,cC,cB,cC,cFl},16,E) then return end
    if not sec("⬛ BREAK",{bA,bA,bB,bC,bF},8,E) then return end
    if not sec("‼ BLAST",{xA,xB},16,E) then return end
    if not sec("↓ FILL",{fA},16,E) then return end
    sec("→ LOOP",{tA},8,E)
end

-- ════════════════════════════════════════════
-- §11  PATTERN REGISTRY + START/STOP
-- ════════════════════════════════════════════
local PATS = {
    {name="Rock",bpm=120,fn=rockLoop},
    {name="Eyeless♫",bpm=142,fn=eyelessLoop,premium=true},
    {name="MIDI",bpm=0,fn=midiLoop},
}

local function go()
    if _G._AD then return end; _G._AD=true; barN=0
    task.spawn(function() while _G._AD do
        local s,e=pcall(PATS[pIdx].fn)
        if not s then warn("[Drum] "..tostring(e)); task.wait(0.3) end
    end end)
end
local function stop()
    _G._AD=false; secN="IDLE"
    pcall(function() for _,v in pairs(K) do VIM:SendKeyEvent(false,v,false,game) end end)
end

