-- ════════════════════════════════════════════
-- REFRESH LOGIC
-- ════════════════════════════════════════════
local SC={["Rock"]=C.grn,["⚡ INTRO"]=C.t3,["♫ VERSE"]=C.blu,["♫ VRS.2"]=C.blu,["⬆ PRE-CH"]=C.acc,["⬆ PRE-C2"]=C.acc,
["★ CHORUS"]=Color3.fromRGB(230,100,30),["★ CHOR.2"]=Color3.fromRGB(220,70,15),["⬛ BREAK"]=Color3.fromRGB(140,60,200),
["‼ BLAST"]=C.red,["↓ FILL"]=C.acc,["→ LOOP"]=C.grn,["NO MIDI"]=C.red,["↻ LOOP"]=C.grn,["⏭ NEXT"]=C.blu,["IDLE"]=C.t3}

local function clearHL()for i,q in ipairs(qBtns)do for _,c in ipairs(q.row:GetChildren())do if c:IsA("UIStroke")then c:Destroy()end end end end
local function hlSong(name)clearHL();for i,q in ipairs(qBtns)do if PRESETS[i].name==name then local s=Instance.new("UIStroke",q.row);s.Color=C.acc;s.Thickness=2 end end end

local function refresh()
    -- Time
    pcall(function()timeLbl.Text=os.date("%H:%M")end)

    -- Toggle button
    if _G._AD then togBtn.Text="⏸  Stop";togBtn.BackgroundColor3=C.red;statusDot.BackgroundColor3=C.grn;statusTxt.Text="playing"
    else togBtn.Text="▶  Play";togBtn.BackgroundColor3=C.grn;statusDot.BackgroundColor3=C.togOff;statusTxt.Text="idle" end

    -- Pattern button
    patBtn.Text=PATS[pIdx].name.." ▸"
    spdBtn.Text=speedMul.."x ▸"
    spdDisp.Text=speedMul.."x"

    -- BPM
    local bStr=(pIdx==3 and midiObj)and tostring(midiObj.bpm)or(pIdx==3 and"---"or tostring(PATS[pIdx].bpm))
    npBPM.Text=bStr.." BPM"

    -- Now Playing
    if currentSong~=""then npName.Text=currentSong;npArtist.Text="Playing · "..bStr.." BPM"
    elseif _G._AD then npName.Text=PATS[pIdx].name;npArtist.Text="Pattern mode"
    else npName.Text="Not Playing";npArtist.Text="Select a song" end

    -- Section
    secLbl.Text=secN;secVal.Text="";secVal.TextColor3=SC[secN]or C.t3
    local sCol=SC[secN]or C.t3
    secLbl.TextColor3=sCol

    -- Progress
    local pct=math.clamp(midiProgress,0,1)
    progFill.Size=UDim2.new(pct,0,1,0)
    progFill.BackgroundColor3=pct>=1 and C.grn or C.acc
    if pIdx==3 and midiObj then progTime.Text=midiTimeStr.." · "..math.floor(pct*100).."%"
    else progTime.Text="Pattern mode · ∞" end

    -- Stats
    statVals.hits.Text=tostring(totalHits)
    statVals.nps.Text=tostring(getNPS())
    statVals.loops.Text=tostring(loopCount)
    statVals.bars.Text=tostring(barN)

    -- MIDI label
    if midiObj and not midiLoading then
        midiLbl.Text="✅ "..midiObj.noteCount.."n · "..string.format("%.0fs",midiObj.duration)
        midiLbl.TextColor3=C.grn
    elseif not midiLoading then midiLbl.Text="No MIDI loaded";midiLbl.TextColor3=C.t3 end
end

task.spawn(function()while gui and gui.Parent do pcall(refresh);task.wait(0.25)end end)

-- ════════════════════════════════════════════
-- ACTIONS
-- ════════════════════════════════════════════
local function toggle()if _G._AD then stop()else go()end;refresh()end
local function cyclePattern()local was=_G._AD;if was then stop();task.wait(0.15)end;local n=pIdx+1;if n>2 then n=1 end;if PATS[n].premium and not isPremium then n=1 end;pIdx=n;barN=0;introD=true;secN="IDLE";currentSong="";loopCount=0;midiProgress=0;clearHL();refresh();if was then go();refresh()end end

doLoadMidi=function(url,songName)
    if midiLoading then return end;midiLoading=true;local was=_G._AD;if was then stop();task.wait(0.15)end
    loadBtn.Text="⏳...";hlSong(songName or"")
    task.spawn(function()
        local data,err=loadMidi(url,function(msg)midiLbl.Text="⏳ "..msg;midiLbl.TextColor3=C.acc end)
        midiLoading=false;loadBtn.Text="📥 Load"
        if data then
            midiObj=data;currentSong=songName or"Custom";pIdx=3;barN=0;secN="IDLE";loopCount=0;midiProgress=0
            for i,p in ipairs(PRESETS)do if p.name==songName then activeSongIdx=i;break end end
            hlSong(songName or"");refresh();task.wait(0.2)
            if not _G._AD then go();refresh()end
            pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{Title="🥁 "..currentSong,Text=data.noteCount.." notes · "..data.bpm.." BPM",Duration=3})end)
        else midiLbl.Text="❌ "..tostring(err):sub(1,25);midiLbl.TextColor3=C.red;clearHL()end
    end)
end

-- ════════════════════════════════════════════
-- CONNECTIONS
-- ════════════════════════════════════════════
togBtn.MouseButton1Click:Connect(toggle)
patBtn.MouseButton1Click:Connect(cyclePattern)
spdBtn.MouseButton1Click:Connect(function()speedIdx=speedIdx%#SPEEDS+1;speedMul=SPEEDS[speedIdx];refresh()end)

loadBtn.MouseButton1Click:Connect(function()
    if not isPremium and customLoads>=1 then midiLbl.Text="🔒 Premium for more";midiLbl.TextColor3=C.acc;return end
    local url=urlBox.Text:match("^%s*(.-)%s*$")
    if url and url~=""then customLoads=customLoads+1;activeSongIdx=nil;doLoadMidi(url,url:match("([^/]+)%.mid")or"Custom")
    else midiLbl.Text="⚠ Paste URL first!";midiLbl.TextColor3=C.acc end
end)

-- Key upgrade (in settings)
keyUBtn.MouseButton1Click:Connect(function()
    if isPremium then pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{Title="⭐",Text="Already Premium!",Duration=2})end);return end
    local kd=Instance.new("Frame",gui);kd.Size=UDim2.new(0,240,0,120);kd.Position=UDim2.new(0.5,-120,0.35,0);kd.BackgroundColor3=C.bg;kd.BorderSizePixel=0;kd.Active=true;kd.Draggable=true;kd.ZIndex=20;mkCorner(kd,12);mkStroke(kd,C.div,1.5)
    mkLbl(kd,UDim2.new(1,0,0,18),UDim2.new(0,0,0,6),"🔑 Enter Key",C.t1,12,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    local kb=Instance.new("TextBox",kd);kb.Size=UDim2.new(0.82,0,0,28);kb.Position=UDim2.new(0.09,0,0,28);kb.BackgroundColor3=C.card;kb.BorderSizePixel=0;kb.Text="";kb.PlaceholderText=" KEY-HERE";kb.PlaceholderColor3=C.t4;kb.TextColor3=C.t1;kb.TextSize=12;kb.Font=Enum.Font.GothamBold;mkCorner(kb,8);mkStroke(kb,C.div)
    Instance.new("UIPadding",kb).PaddingLeft=UDim.new(0,8)
    local ku=mkBtn(kd,UDim2.new(0.38,0,0,26),UDim2.new(0.06,0,0,64),C.dark,"unlock",C.white,10)
    local kc=mkBtn(kd,UDim2.new(0.38,0,0,26),UDim2.new(0.56,0,0,64),C.card,"cancel",C.t2,10);mkStroke(kc,C.div)
    local ks=mkLbl(kd,UDim2.new(1,0,0,12),UDim2.new(0,0,0,96),"",C.t3,9);ks.TextXAlignment=Enum.TextXAlignment.Center
    ku.MouseButton1Click:Connect(function()if checkKey(kb.Text)then isPremium=true;_G._DrumPremium=true;ks.Text="✅ Unlocked!";ks.TextColor3=C.grn;task.wait(1);kd:Destroy();stop();task.wait(0.1);gui:Destroy();loadMain()else ks.Text="❌ Invalid!";ks.TextColor3=C.red end end)
    kc.MouseButton1Click:Connect(function()kd:Destroy()end)
end)

-- Window controls
minBtn.MouseButton1Click:Connect(function()guiOpen=false;mf.Visible=false;miniBtn.Visible=true end)
miniBtn.MouseButton1Click:Connect(function()guiOpen=true;mf.Visible=true;miniBtn.Visible=false end)
maxBtn.MouseButton1Click:Connect(function()
    if mf.Size.X.Offset>=400 then mf.Size=UDim2.new(0,340,0,415);mf.Position=UDim2.new(0.5,-170,0.5,-207)
    else mf.Size=UDim2.new(0,420,0,480);mf.Position=UDim2.new(0.5,-210,0.5,-240)end
end)
clsBtn.MouseButton1Click:Connect(function()stop();task.wait(0.1);gui:Destroy();if kConn then kConn:Disconnect()end;_G._AD=nil end)

kConn=UIS.InputBegan:Connect(function(i,gp)if gp then return end;if i.KeyCode==Enum.KeyCode.P then toggle()end end)

-- Mini pulse
task.spawn(function()local p=0;while gui and gui.Parent do if not guiOpen and _G._AD then p=p+1;miniBtn.BackgroundTransparency=0.08+0.08*math.sin(p*0.4)end;task.wait(0.1)end end)

-- ═══ STARTUP ═══
applyFilter("All");refresh()
pcall(function()game:GetService("StarterGui"):SetCore("SendNotification",{
    Title="🥁 Auto Drum [Reworked]",Text=(isPremium and"⭐ Premium" or"🆓 Free").." · v8.0 · Tap a song!",Duration=4})end)
print("═══════════════════════════════════════════")
print("  🥁 AUTO DRUM [REWORKED] v8.0 ✅")
print("  "..(isPremium and"⭐ PREMIUM" or"🆓 FREE").." │ Sidebar GUI │ 5 Tabs")
print("  Songs·Player·Settings·Info·Credits")
print("  "..#PRESETS.." songs │ Press P or tap ▶")
print("═══════════════════════════════════════════")
end -- end loadMain

-- ═══ ENTRY POINT ═══
if _G._DrumValidated then isPremium=_G._DrumPremium or false;loadMain()
else showKeyGUI(function()loadMain()end)end
