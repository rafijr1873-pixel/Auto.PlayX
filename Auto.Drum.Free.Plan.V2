-- ═══ TAB SWITCHING ═══
local function switchTab(idx)
    curTab=idx
    for i=1,5 do
        tabFrames[i].Visible=(i==idx)
        tabBtns[i].btn.BackgroundTransparency=i==idx and 0 or 1
        tabBtns[i].accent.Visible=(i==idx)
        tabBtns[i].label.TextColor3=i==idx and C.t1 or C.t3
    end
end
for i=1,5 do tabBtns[i].btn.MouseButton1Click:Connect(function()switchTab(i)end)end

