local function showKeyGUI(onDone)
    local kg=Instance.new("ScreenGui",pgui);kg.Name="DrumKeyGUI";kg.ResetOnSpawn=false;kg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
    local bg=Instance.new("Frame",kg);bg.Size=UDim2.new(1,0,1,0);bg.BackgroundColor3=Color3.new(0,0,0);bg.BackgroundTransparency=0.4;bg.BorderSizePixel=0
    local card=Instance.new("Frame",bg);card.Size=UDim2.new(0,310,0,380);card.Position=UDim2.new(0.5,-155,0.5,-190);card.BackgroundColor3=C.bg;card.BackgroundTransparency=0.03;card.BorderSizePixel=0;card.Active=true;card.Draggable=true;mkCorner(card,16);mkStroke(card,C.div,1.5)

    mkLbl(card,UDim2.new(1,0,0,26),UDim2.new(0,0,0,16),"🥁 Auto Drum [Reworked]",C.t1,18,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    mkLbl(card,UDim2.new(1,0,0,14),UDim2.new(0,0,0,44),"Virtual Drums · v8.0",C.t3,10).TextXAlignment=Enum.TextXAlignment.Center

    local dv=Instance.new("Frame",card);dv.Size=UDim2.new(0.85,0,0,1);dv.Position=UDim2.new(0.075,0,0,66);dv.BackgroundColor3=C.div;dv.BorderSizePixel=0

    local function cl(txt,x,y,col)local l=mkLbl(card,UDim2.new(0.44,0,0,13),UDim2.new(x,0,0,y),txt,col,8);l.TextXAlignment=Enum.TextXAlignment.Center;return l end
    mkLbl(card,UDim2.new(0.44,0,0,15),UDim2.new(0.03,0,0,74),"🆓 FREE",C.t2,11,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    mkLbl(card,UDim2.new(0.44,0,0,15),UDim2.new(0.53,0,0,74),"⭐ PREMIUM",C.acc,11,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    local fData={{92,"✅ Rock Beat",C.grn},{106,"✅ 3 Songs",C.grn},{120,"✅ 1 Custom",C.grn},{134,"❌ All Songs",C.red},{148,"❌ Shuffle",C.red},{162,"❌ AutoNext",C.red}}
    local pData={{92,"✅ Rock Beat"},{106,"✅ 11 Songs"},{120,"✅ Unlimited"},{134,"✅ All Songs"},{148,"✅ Shuffle"},{162,"✅ AutoNext"}}
    for _,d in ipairs(fData)do cl(d[2],0.03,d[1],d[3])end
    for _,d in ipairs(pData)do cl(d[2],0.53,d[1],C.grn)end

    local dv2=Instance.new("Frame",card);dv2.Size=UDim2.new(0.85,0,0,1);dv2.Position=UDim2.new(0.075,0,0,182);dv2.BackgroundColor3=C.div;dv2.BorderSizePixel=0

    mkLbl(card,UDim2.new(1,0,0,16),UDim2.new(0,0,0,192),"🔑 Enter Premium Key",C.t1,13,Enum.Font.GothamBold).TextXAlignment=Enum.TextXAlignment.Center
    local keyBox=Instance.new("TextBox",card);keyBox.Size=UDim2.new(0.82,0,0,36);keyBox.Position=UDim2.new(0.09,0,0,214);keyBox.BackgroundColor3=C.card;keyBox.BorderSizePixel=0;keyBox.Text="";keyBox.PlaceholderText="  XXXXX-XXXXX-XXXXX";keyBox.PlaceholderColor3=C.t4;keyBox.TextColor3=C.t1;keyBox.TextSize=14;keyBox.Font=Enum.Font.GothamBold;keyBox.ClearTextOnFocus=false;mkCorner(keyBox,10);mkStroke(keyBox,C.div)
    Instance.new("UIPadding",keyBox).PaddingLeft=UDim.new(0,10)

    local ulBtn=mkBtn(card,UDim2.new(0.4,0,0,38),UDim2.new(0.05,0,0,262),C.dark,"🔓 Unlock",C.white,13)
    local frBtn=mkBtn(card,UDim2.new(0.4,0,0,38),UDim2.new(0.55,0,0,262),C.card,"▶ Free Mode",C.t1,12);mkStroke(frBtn,C.div)
    local stat=mkLbl(card,UDim2.new(0.9,0,0,14),UDim2.new(0.05,0,0,310),"Enter key or continue free",C.t3,10);stat.TextXAlignment=Enum.TextXAlignment.Center
    mkLbl(card,UDim2.new(1,0,0,12),UDim2.new(0,0,0,332),"🆓 Free: Eyeless · Duality · Before I Forget",C.t4,8).TextXAlignment=Enum.TextXAlignment.Center
    mkLbl(card,UDim2.new(1,0,0,12),UDim2.new(0,0,0,352),"by rafijr1873",C.t4,8).TextXAlignment=Enum.TextXAlignment.Center

    ulBtn.MouseButton1Click:Connect(function()
        if keyBox.Text==""then stat.Text="⚠ Enter a key!";stat.TextColor3=C.acc;return end
        stat.Text="⏳ Validating...";stat.TextColor3=C.t2;task.wait(0.5)
        if checkKey(keyBox.Text)then isPremium=true;_G._DrumPremium=true;_G._DrumValidated=true;stat.Text="✅ PREMIUM UNLOCKED!";stat.TextColor3=C.grn;ulBtn.Text="✅";task.wait(1);kg:Destroy();onDone()
        else stat.Text="❌ Invalid key!";stat.TextColor3=C.red;task.wait(1.5);stat.TextColor3=C.t3 end
    end)
    frBtn.MouseButton1Click:Connect(function()isPremium=false;_G._DrumPremium=false;_G._DrumValidated=true;stat.Text="▶ Loading...";task.wait(0.4);kg:Destroy();onDone()end)
end

