-- ═══ ENGINE ═══
local function hum(f)local ms=f and RNG:NextInteger(5,16)or RNG:NextInteger(16,45);return(ms/1000)*((RNG:NextInteger(0,1)==0)and 1 or-1)end
local function press(keys,f)if typeof(keys)=="EnumItem"then keys={keys}end;for i=1,#keys do VIM:SendKeyEvent(true,keys[i],false,game)end;task.wait(f and RNG:NextInteger(22,42)/1000 or RNG:NextInteger(48,100)/1000);for i=1,#keys do VIM:SendKeyEvent(false,keys[i],false,game)end;totalHits=totalHits+1;local now=tick();recentHits[#recentHits+1]=now;while #recentHits>0 and now-recentHits[1]>3 do table.remove(recentHits,1)end end
local function getNPS()local now=tick();while #recentHits>0 and now-recentHits[1]>3 do table.remove(recentHits,1)end;return math.floor(#recentHits/3*10)/10 end
local function ok()return _G._AD end
local function bar(pat,sub,bpm)barN=barN+1;local base=(60/bpm/(sub==16 and 4 or 2))/speedMul;local f=sub==16;for i=1,#pat do if not ok()then return false end;if pat[i]then press(pat[i],f)end;local d=base+hum(f)/speedMul;if d<0.02 then d=0.02 end;task.wait(d)end;return ok()end
local function sec(name,bars,sub,bpm)secN=name;for i=1,#bars do if not bar(bars[i],sub,bpm)then return false end end;return ok()end

-- ═══ MIDI PARSER (compact) ═══
local MP={}
function MP.parse(raw)if not raw or #raw<14 then return nil,"File too small"end;local pos,len=1,#raw;local function rb()if pos>len then error("EOF")end;local b=string.byte(raw,pos);pos=pos+1;return b end;local function rn(n)local v=0;for _=1,n do v=v*256+rb()end;return v end;local function rs(n)if pos+n-1>len then error("EOF")end;local s=raw:sub(pos,pos+n-1);pos=pos+n;return s end;local function rvlq()local v,c=0,0;repeat local b=rb();v=v*128+(b%128);c=c+1;if c>4 then error("VLQ")end until b<128;return v end;local hdr=rs(4);if hdr~="MThd"then return nil,"Not MIDI"end;local hl=rn(4);rn(2);local nT=rn(2);local div=rn(2);if hl>6 then pos=pos+(hl-6)end;if div>=32768 then return nil,"SMPTE"end;local ppq,notes,tempos=div,{},{};for t=1,nT do if pos+8>len then break end;local th=rs(4);if th~="MTrk"then return nil,"No MTrk"end;local tl=rn(4);local te=pos+tl;local at,run=0,0;while pos<te and pos<=len do local d=rvlq();at=at+d;if pos>len then break end;local pk=string.byte(raw,pos);if not pk then break end;local st;if pk>=128 then st=rb();if st<0xF0 then run=st end else st=run;if st==0 then rb();break end end;local hi=math.floor(st/16);if hi==9 then local n,v=rb(),rb();if v>0 and #notes<30000 then notes[#notes+1]={at,n,v,st%16}end elseif hi==8 or hi==10 or hi==11 or hi==14 then rb();rb()elseif hi==12 or hi==13 then rb()elseif st==0xFF then local mt=rb();local ml=rvlq();if mt==0x51 and ml>=3 then local us=0;for _=1,3 do us=us*256+rb()end;tempos[#tempos+1]={at,us};if ml>3 then pos=pos+(ml-3)end else pos=pos+ml end elseif st==0xF0 or st==0xF7 then pos=pos+rvlq()else pos=te end end;pos=te end;if #notes==0 then return nil,"No notes"end;table.sort(notes,function(a,b)return a[1]<b[1]end);table.sort(tempos,function(a,b)return a[1]<b[1]end);return notes,tempos,ppq end
function MP.build(notes,tempos,ppq)local has9=false;for _,n in ipairs(notes)do if n[4]==9 then has9=true;break end end;local dn={};for _,n in ipairs(notes)do if(has9 and n[4]==9)or not has9 then local key=GM[n[2]];if key then dn[#dn+1]={tick=n[1],key=key}end end end;if #dn==0 then return nil,0,0,0,"No drum"end;if #tempos==0 or tempos[1][1]~=0 then table.insert(tempos,1,{0,500000})end;local tl={};local cs,pt,ptm=0,0,500000;for _,tc in ipairs(tempos)do cs=cs+(tc[1]-pt)*ptm/ppq/1e6;tl[#tl+1]={tick=tc[1],sec=cs,tempo=tc[2]};pt=tc[1];ptm=tc[2]end;local function t2s(tick)local s,p,tm=0,0,500000;for _,t in ipairs(tl)do if t.tick>tick then break end;s=t.sec;p=t.tick;tm=t.tempo end;return s+(tick-p)*tm/ppq/1e6 end;local gr,tks={},{};for _,d in ipairs(dn)do local t=d.tick;if not gr[t]then gr[t]={};tks[#tks+1]=t end;local dup=false;for _,k in ipairs(gr[t])do if k==d.key then dup=true end end;if not dup then gr[t][#gr[t]+1]=d.key end end;table.sort(tks);local seq={};for _,t in ipairs(tks)do seq[#seq+1]={time=t2s(t),keys=gr[t]}end;return seq,seq[#seq]and seq[#seq].time or 0,math.floor(60e6/(tempos[1][2]or 5e5)+0.5),#dn,nil end

-- ═══ MIDI LOAD & PLAY ═══
local function fetch(url)local body,s,e;s,e=pcall(function()if syn and syn.request then body=syn.request({Url=url,Method="GET"}).Body elseif http_request then body=http_request({Url=url,Method="GET"}).Body elseif request then body=request({Url=url,Method="GET"}).Body elseif httpget then body=httpget(url)else body=game:HttpGet(url)end end);return s and body or nil,tostring(e or"")end
local function loadMidi(url,cb)if not url or url==""then return nil,"No URL"end;cb("Fetching...");local raw,fe=fetch(url);if not raw then return nil,"Fetch: "..(fe or"?")end;if #raw<14 then return nil,"Too small"end;cb("Parsing...");local notes,tempos,ppq=MP.parse(raw);if not notes then return nil,tempos end;cb("Building...");local seq,dur,bpm,cnt,err=MP.build(notes,tempos,ppq);if not seq then return nil,err end;return{seq=seq,duration=dur,bpm=bpm,noteCount=cnt}end
local function fmtTime(s)s=math.max(0,math.floor(s));return string.format("%d:%02d",math.floor(s/60),s%60)end
local function getAvail()local a={};for i=1,#PRESETS do if isPremium or isSongFree(i)then a[#a+1]=i end end;return a end
local function pickNext()local a=getAvail();if #a==0 then return nil end;if shuffleOn then return a[RNG:NextInteger(1,#a)]end;if not activeSongIdx then return a[1]end;for i,idx in ipairs(a)do if idx==activeSongIdx then return a[(i%#a)+1]end end;return a[1]end

local function midiLoop()if not midiObj or #midiObj.seq==0 then secN="NO MIDI";task.wait(1);return end;secN="♫ "..currentSong;local seq=midiObj.seq;local dur=midiObj.duration/speedMul;local st=tick();for i=1,#seq do if not ok()then midiProgress=0;return end;local tgt=st+seq[i].time/speedMul;if tgt>tick()+0.003 then task.wait(tgt-tick())end;if not ok()then midiProgress=0;return end;press(seq[i].keys,true);barN=math.floor(i/16);midiProgress=i/#seq;midiTimeStr=fmtTime(tick()-st).."/"..fmtTime(dur)end;loopCount=loopCount+1;midiProgress=1;if autoNextOn and ok()then secN="⏭ NEXT";task.wait(0.8);if ok()then local nxt=pickNext();if nxt then _G._AD=false;task.wait(0.15);activeSongIdx=nxt;doLoadMidi(PRESETS[nxt].url,PRESETS[nxt].name);return end end else secN="↻ LOOP";task.wait(0.5)end end

-- ═══ PATTERNS (compact) ═══
local E=142
local rA={{K.Ki,K.HC},{K.HC},{K.Sn,K.HC},{K.HC},{K.Ki,K.HC},{K.HC},{K.Sn,K.HC},{K.HC}}
local rB={{K.Ki,K.HC},{K.HC},{K.Sn,K.HC},{K.Rd},{K.Ki,K.HC},{K.HO},{K.Sn,K.HC,K.T2},{K.HC}}
local rC={{K.Ki,K.CR},{K.HC},{K.Sn,K.HC},{K.HC},{K.Ki,K.HC},{K.HO},{K.Sn,K.HC},{K.HC}}
local rF={{K.Ki,K.HC},{K.HC},{K.T1,K.HC},{K.T2},{K.T3,K.Ki},{K.T3B},{K.Sn,K.Ki,K.CR},{K.CL,K.Ki}}
local function rockLoop()secN="Rock";local b=barN;if b>0 and b%16==0 then bar(rF,8,120)elseif b>0 and b%8==0 and RNG:NextNumber()<0.25 then bar(rC,8,120)elseif b%4==3 and RNG:NextNumber()<0.45 then bar(rB,8,120)else bar(rA,8,120)end end
local iA={{K.Ki,K.Ch},nil,nil,nil,{K.Ki,K.Ch},nil,nil,nil}local iB={{K.Ki,K.Ch},nil,{K.Sn},nil,{K.Ki,K.Ch},nil,{K.Sn},nil}local iC={{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ch},{K.Ki2}}local iD={{K.T1,K.Ki},{K.T1B,K.Ki2},{K.T2,K.Ki},{K.T2B,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.SnS,K.Ki},{K.CL,K.CR,K.Ch,K.Ki,K.Ki2}}
local vA={{K.Ki,K.RB},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.RB},{K.Ki,K.RB},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.RB}}local vB={{K.Ki,K.RB},{K.Ki2,K.Sn2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.RB},{K.Ki,K.Sn2,K.RB},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.Sn2,K.RB}}local vC={{K.Ki,K.RB},{K.Ki2,K.RB},{K.Sn,K.Ki,K.Ch},{K.Ki2,K.RB},{K.Ki,K.RB},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.Ch}}local vD={{K.Ki,K.RB},{K.Ki2,K.HO},{K.Sn,K.Ki,K.RB},{K.Ki2,K.RB},{K.Ki,K.RB},{K.Ki2,K.HO},{K.Sn,K.Ki,K.Ch},{K.Ki2,K.RB}}
local pA={{K.Ki,K.Ki2,K.CR},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.RB},{K.Ki,K.Ch},{K.Ki2,K.RB},{K.Sn,K.Ki,K.RB},{K.Ki2,K.Ch}}local pB={{K.Ki,K.Ki2,K.CL},{K.Ki2,K.Sn2},{K.Sn,K.Ki,K.CR},{K.Ki2,K.RB},{K.Ki,K.Ch},{K.Ki2,K.Sn2},{K.Sn,K.Ki,K.Ch},{K.Ki2,K.CR}}local pF={{K.Ki,K.CR},{K.Ki2,K.Sn2},{K.Sn,K.Ki,K.CL},{K.Ki2},{K.T1,K.Ki},{K.T2,K.Ki2},{K.T3,K.Ki},{K.Sn,K.CR,K.CL,K.Ki,K.Ki2}}
local cA={{K.Ki,K.Ki2,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CR},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CL},{K.Ki2},{K.Ki,K.Ch},{K.Ki2}}local cB={{K.Ki,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2,K.Sn2},{K.Sn,K.Ki,K.CR},{K.Ki2},{K.Ki,K.Sp},{K.Ki2},{K.Ki,K.Ki2,K.Ch},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CL,K.CR},{K.Ki2},{K.Ki,K.Ch},{K.Ki2,K.Ki}}local cC={{K.Ki,K.Ki2,K.Ch,K.CR},{K.Ki2},{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CL},{K.Ki2},{K.Ki,K.Ch},{K.Ki2,K.Sn2},{K.Ki,K.Ch},{K.Ki2},{K.Ki,K.Ki2,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CR,K.CL},{K.Ki2},{K.Ki,K.Ch,K.Sp},{K.Ki2,K.Ki}}local cFl={{K.Ki,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.CR},{K.Ki2},{K.T1,K.Ki},{K.T1B,K.Ki2},{K.T2,K.Ki},{K.T2B,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.Ki},{K.Sn2,K.Ki2},{K.Sn,K.SnS,K.Ki,K.Ki2},{K.Ki2},{K.Sn,K.Ki},{K.CL,K.CR,K.Ch,K.Ki,K.Ki2}}
local bA={{K.Ki,K.Ki2,K.Ch},nil,{K.Sn,K.Ch},nil,{K.Ki,K.Ki2,K.Ch},{K.T3},{K.Sn,K.CR},nil}local bB={{K.Ki,K.Ki2,K.Ch},{K.T1},{K.Sn,K.T2},{K.T3},{K.Ki,K.Ch},{K.T2},{K.Sn,K.T3},{K.Ki2,K.T1}}local bC={{K.Ki,K.Ki2,K.Ch},{K.Ki2},{K.Sn,K.Ki,K.Ch},{K.Ki2},{K.Ki,K.Ki2,K.Ch},{K.Ki2,K.T3},{K.Sn,K.Ki,K.CR,K.CL},{K.Ki2}}local bF={{K.Ki,K.Ki2,K.CR},{K.Sn2},{K.T1,K.Ki},{K.T1B,K.Ki2},{K.T2,K.Ki},{K.T2B,K.Ki2},{K.T3,K.Ki},{K.Sn,K.SnS,K.CR,K.CL,K.Ch,K.Ki,K.Ki2}}
local xA={{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2}}local xB={{K.Ki,K.Sn,K.CR},{K.Ki2},{K.Ki,K.Sn,K.CL},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.CR},{K.Ki2},{K.Ki,K.Sn,K.CL},{K.Ki2},{K.Ki,K.Sn,K.Ch},{K.Ki2},{K.Ki,K.Sn,K.CR},{K.Ki2},{K.Ki,K.Sn,K.CL,K.Ch},{K.Ki2}}
local fA={{K.Sn,K.CR},{K.Sn2},{K.T1,K.Ki},{K.T1B,K.Ki2},{K.T2,K.Ki},{K.T2B,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.Ki,K.Ki2},{K.Sn},{K.T1,K.Ki},{K.T2,K.Ki2},{K.T3,K.Ki},{K.T3B,K.Ki2},{K.Sn,K.SnS,K.Ki,K.Ki2},{K.CL,K.CR,K.Ch,K.Ki,K.Ki2}}local tA={{K.CL,K.CR,K.Ch,K.Sp,K.Ki,K.Ki2},nil,nil,nil,nil,nil,nil,nil}
local function eyelessLoop()if introD then introD=false;if not sec("⚡ INTRO",{iA,iB,iC,iD},8,E)then return end end;if not sec("♫ VERSE",{vA,vA,vB,vC,vA,vB,vD,vC},8,E)then return end;if not sec("⬆ PRE-CH",{pA,pB,pF},8,E)then return end;if not sec("★ CHORUS",{cA,cA,cB,cA,cFl},16,E)then return end;if not sec("♫ VRS.2",{vB,vD,vC,vB},8,E)then return end;if not sec("⬆ PRE-C2",{pB,pA,pF},8,E)then return end;if not sec("★ CHOR.2",{cA,cC,cB,cC,cFl},16,E)then return end;if not sec("⬛ BREAK",{bA,bA,bB,bC,bF},8,E)then return end;if not sec("‼ BLAST",{xA,xB},16,E)then return end;if not sec("↓ FILL",{fA},16,E)then return end;sec("→ LOOP",{tA},8,E)end

local PATS={{name="Rock",bpm=120,fn=rockLoop},{name="Eyeless♫",bpm=142,fn=eyelessLoop,premium=true},{name="MIDI",bpm=0,fn=midiLoop}}
local function go()if _G._AD then return end;_G._AD=true;barN=0;midiProgress=0;task.spawn(function()while _G._AD do local s,e=pcall(PATS[pIdx].fn);if not s then warn("[Drum]"..tostring(e));task.wait(0.3)end end end)end
local function stop()_G._AD=false;secN="IDLE";midiProgress=0;pcall(function()for _,v in pairs(K)do VIM:SendKeyEvent(false,v,false,game)end end)end

-- ═══ ANTI-AFK ═══
task.spawn(function()while true do if antiAfk then pcall(function()VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game);task.wait(0.05);VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game)end)end;task.wait(180)end end)
pcall(function()plr.Idled:Connect(function()if antiAfk then VIM:SendKeyEvent(true,Enum.KeyCode.Return,false,game);task.wait(0.1);VIM:SendKeyEvent(false,Enum.KeyCode.Return,false,game)end end)end)

-- ═══ AUTO-SIT ═══
local function autoSit()local c=plr.Character;if not c then return false,"No character"end;local root=c:FindFirstChild("HumanoidRootPart");local hum=c:FindFirstChildOfClass("Humanoid");if not root or not hum then return false,"No humanoid"end;if hum.Sit then return false,"Already sitting"end;local best,dist=nil,math.huge;for _,obj in ipairs(workspace:GetDescendants())do pcall(function()if(obj:IsA("Seat")or obj:IsA("VehicleSeat"))and not obj.Occupant then local d=(obj.Position-root.Position).Magnitude;if d<dist then best=obj;dist=d end end end)end;if best and dist<100 then root.CFrame=best.CFrame+Vector3.new(0,3,0);task.wait(0.5);pcall(function()best:Sit(hum)end);return true,"Seated! ("..math.floor(dist).."m)"end;return false,"No seat nearby"end

-- ═══ GUI HELPERS ═══
local function mkCorner(p,r)local c=Instance.new("UICorner",p);c.CornerRadius=UDim.new(0,r or 10);return c end
local function mkStroke(p,col,th)local s=Instance.new("UIStroke",p);s.Color=col or C.str;s.Thickness=th or 1;s.Transparency=0.5;return s end
local function mkLbl(p,sz,ps,txt,col,ts,fnt)local l=Instance.new("TextLabel",p);l.Size=sz;l.Position=ps;l.BackgroundTransparency=1;l.Text=txt;l.TextColor3=col or C.t1;l.TextSize=ts or 11;l.Font=fnt or Enum.Font.Gotham;l.TextXAlignment=Enum.TextXAlignment.Left;return l end
local function mkBtn(p,sz,ps,bg,txt,tc,ts)local b=Instance.new("TextButton",p);b.Size=sz;b.Position=ps;b.BackgroundColor3=bg;b.Text=txt;b.TextColor3=tc or C.white;b.TextSize=ts or 11;b.Font=Enum.Font.GothamBold;b.AutoButtonColor=true;b.BorderSizePixel=0;mkCorner(b,8);return b end

local function mkToggle(p,x,y,on,fn,prem)
    local bg=Instance.new("Frame",p);bg.Size=UDim2.new(0,44,0,22);bg.Position=UDim2.new(1,-56,0,y);bg.BackgroundColor3=on and C.togOn or C.togOff;bg.BorderSizePixel=0;mkCorner(bg,11)
    local knob=Instance.new("Frame",bg);knob.Size=UDim2.new(0,18,0,18);knob.Position=on and UDim2.new(0,24,0,2)or UDim2.new(0,2,0,2);knob.BackgroundColor3=C.knob;knob.BorderSizePixel=0;mkCorner(knob,9)
    local btn=Instance.new("TextButton",bg);btn.Size=UDim2.new(1,0,1,0);btn.BackgroundTransparency=1;btn.Text=""
    local isOn=on
    btn.MouseButton1Click:Connect(function()
        if prem and not isPremium then return end
        isOn=not isOn;bg.BackgroundColor3=isOn and C.togOn or C.togOff
        TS:Create(knob,TweenInfo.new(0.15),{Position=isOn and UDim2.new(0,24,0,2)or UDim2.new(0,2,0,2)}):Play()
        if fn then fn(isOn)end
    end)
    return bg,function()return isOn end
end

local function mkCard(p,y,txt,h)
    h=h or 44;local f=Instance.new("Frame",p);f.Size=UDim2.new(1,-12,0,h);f.Position=UDim2.new(0,6,0,y);f.BackgroundColor3=C.card;f.BorderSizePixel=0;mkCorner(f,10)
    local l=mkLbl(f,UDim2.new(0.6,0,1,0),UDim2.new(0,14,0,0),txt,C.t1,12,Enum.Font.GothamBold)
    return f,l
end

