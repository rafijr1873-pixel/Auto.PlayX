local tagMap={All="All",Slipknot="SK",Megadeth="MG",A7X="A7X"}
local filterBtns={}
for i,fn in ipairs(FNAMES) do
    local fb=mkBtn(t1,UDim2.new(0,56,0,22),UDim2.new(0,6+(i-1)*59,0,4),i==1 and C.dark or C.card,fn,i==1 and C.white or C.t2,8)
    if i>1 then mkStroke(fb,C.div,0.5)end
    filterBtns[i]=fb
end

-- Song list scroll
local songScroll=Instance.new("Frame",t1);songScroll.Size=UDim2.new(1,-8,0,0);songScroll.Position=UDim2.new(0,4,0,32);songScroll.BackgroundTransparency=1;songScroll.BorderSizePixel=0;songScroll.AutomaticSize=Enum.AutomaticSize.Y
local songLayout=Instance.new("UIListLayout",songScroll);songLayout.Padding=UDim.new(0,4);songLayout.SortOrder=Enum.SortOrder.LayoutOrder

local qBtns={}
for i,preset in ipairs(PRESETS) do
    local free=isSongFree(i);local locked=not isPremium and not free
    local row=Instance.new("Frame",songScroll);row.Size=UDim2.new(1,-4,0,40);row.LayoutOrder=i;row.BackgroundColor3=C.card;row.BorderSizePixel=0;row.AutomaticSize=Enum.AutomaticSize.None;mkCorner(row,10)
    if locked then row.BackgroundTransparency=0.4 end

    -- Color stripe
    local stripe=Instance.new("Frame",row);stripe.Size=UDim2.new(0,4,0.7,0);stripe.Position=UDim2.new(0,0,0.15,0);stripe.BackgroundColor3=locked and C.togOff or preset.color;stripe.BorderSizePixel=0;mkCorner(stripe,2)

    local nm=mkLbl(row,UDim2.new(0.55,0,0,16),UDim2.new(0,12,0,4),locked and "🔒 "..preset.name or preset.name,locked and C.t4 or C.t1,11,Enum.Font.GothamBold)
    nm.TextTruncate=Enum.TextTruncate.AtEnd
    mkLbl(row,UDim2.new(0.55,0,0,12),UDim2.new(0,12,0,22),locked and "Premium" or preset.artist,locked and C.t4 or C.t3,8)

    -- Play button
    local playB=mkBtn(row,UDim2.new(0,50,0,26),UDim2.new(1,-58,0,7),locked and C.togOff or C.grn,locked and "🔒" or "▶ Play",C.white,9)
    playB.MouseButton1Click:Connect(function()
        if locked then return end;activeSongIdx=i;doLoadMidi(PRESETS[i].url,PRESETS[i].name)
    end)
    qBtns[i]={row=row,playB=playB,stripe=stripe}
end

-- Custom MIDI section
