local urlBox=Instance.new("TextBox",cWrap);urlBox.Size=UDim2.new(1,-12,0,28);urlBox.Position=UDim2.new(0,6,0,18);urlBox.BackgroundColor3=C.card;urlBox.BorderSizePixel=0;urlBox.Text="";urlBox.PlaceholderText="  Paste .mid URL...";urlBox.PlaceholderColor3=C.t4;urlBox.TextColor3=C.t1;urlBox.TextSize=9;urlBox.Font=Enum.Font.Gotham;urlBox.ClearTextOnFocus=false;urlBox.TextXAlignment=Enum.TextXAlignment.Left;urlBox.TextTruncate=Enum.TextTruncate.AtEnd;mkCorner(urlBox,8);mkStroke(urlBox,C.div)
Instance.new("UIPadding",urlBox).PaddingLeft=UDim.new(0,8)

local loadBtn=mkBtn(cWrap,UDim2.new(0,74,0,24),UDim2.new(0,6,0,52),C.dark,"📥 Load",C.white,9)
local midiLbl=mkLbl(cWrap,UDim2.new(0,150,0,24),UDim2.new(0,86,0,52),"No MIDI loaded",C.t3,8)
midiLbl.TextTruncate=Enum.TextTruncate.AtEnd

-- Filter logic
local function applyFilter(name)
    curFilter=name;local t=tagMap[name]
    for i,fb in ipairs(filterBtns) do
        fb.BackgroundColor3=FNAMES[i]==name and C.dark or C.card
        fb.TextColor3=FNAMES[i]==name and C.white or C.t2
    end
    for i,q in ipairs(qBtns) do q.row.Visible=(t=="All" or PRESETS[i].tag==t)end
end
for i,fb in ipairs(filterBtns) do fb.MouseButton1Click:Connect(function()applyFilter(FNAMES[i])end)end

